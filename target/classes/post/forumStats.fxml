<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" stylesheets="@stats.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.post.ForumStatsController">
   <content>
      <VBox spacing="30.0" style="-fx-padding: 30;">
         <children>
            <!-- Header Section -->
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <VBox spacing="5.0">
                     <children>
                        <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2d3748;" text="Forum Analytics" />
                        <Label style="-fx-font-size: 14px; -fx-text-fill: #718096;" text="Global engagement metrics and top performance insights" />
                     </children>
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button onAction="#refreshStats" style="-fx-background-color: #6366f1; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 10 20; -fx-cursor: hand;" text="🔄 Refresh Data" />
               </children>
            </HBox>

            <!-- Overview Cards -->
            <HBox spacing="25.0">
               <children>
                  <VBox prefWidth="280.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 15, 0, 0, 5);" HBox.hgrow="ALWAYS">
                     <children>
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-weight: bold; -fx-font-size: 12px; -fx-letter-spacing: 1;" text="TOP INFLUENCER" />
                        <Label fx:id="topInfluencerName" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-padding: 10 0 5 0;" text="Loading..." />
                        <Label fx:id="topInfluencerStats" style="-fx-text-fill: #6366f1; -fx-font-weight: bold;" text="0 total activities" />
                     </children>
                  </VBox>
                  <VBox prefWidth="280.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 15, 0, 0, 5);" HBox.hgrow="ALWAYS">
                     <children>
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-weight: bold; -fx-font-size: 12px; -fx-letter-spacing: 1;" text="MOST LIKED POST" />
                        <Label fx:id="mostLikedTitle" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-padding: 10 0 5 0;" text="Loading..." wrapText="true" />
                        <Label fx:id="mostLikedCount" style="-fx-text-fill: #f43f5e; -fx-font-weight: bold;" text="0 likes" />
                     </children>
                  </VBox>
                  <VBox prefWidth="280.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 15, 0, 0, 5);" HBox.hgrow="ALWAYS">
                     <children>
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-weight: bold; -fx-font-size: 12px; -fx-letter-spacing: 1;" text="MOST DISCUSSED" />
                        <Label fx:id="mostDiscussedTitle" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-padding: 10 0 5 0;" text="Loading..." wrapText="true" />
                        <Label fx:id="mostDiscussedCount" style="-fx-text-fill: #10b981; -fx-font-weight: bold;" text="0 comments" />
                     </children>
                  </VBox>
               </children>
            </HBox>

            <HBox spacing="30.0">
               <children>
                  <!-- Charts Section -->
                  <VBox spacing="20.0" HBox.hgrow="ALWAYS">
                     <children>
                        <VBox style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 15, 0, 0, 5);">
                           <children>
                              <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #334155; -fx-padding: 0 0 20 0;" text="User Engagement Leaderboard" />
                              <BarChart fx:id="activityChart" animated="false" legendVisible="false" prefHeight="400.0" title="Community Engagement ranking">
                                <xAxis>
                                  <CategoryAxis label="USERNAME" side="BOTTOM" />
                                </xAxis>
                                <yAxis>
                                  <NumberAxis label="ACTIVITY POINTS" side="LEFT" />
                                </yAxis>
                              </BarChart>
                           </children>
                        </VBox>
                     </children>
                  </VBox>

                  <!-- Side Lists -->
                  <VBox prefWidth="400.0" spacing="20.0">
                     <children>
                        <!-- Top Liked List -->
                        <VBox style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 15, 0, 0, 5);" VBox.vgrow="ALWAYS">
                           <children>
                              <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #334155; -fx-padding: 0 0 15 0;" text="🔥 Popular Posts" />
                              <VBox fx:id="topPostsList" spacing="15.0" />
                           </children>
                        </VBox>

                        <!-- Top Commented List -->
                        <VBox style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 15, 0, 0, 5);" VBox.vgrow="ALWAYS">
                           <children>
                              <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #334155; -fx-padding: 0 0 15 0;" text="💬 Most Discussed" />
                              <VBox fx:id="topCommentedList" spacing="15.0" />
                           </children>
                        </VBox>
                        
                        <!-- Activity Breakdown -->
                        <VBox style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 15, 0, 0, 5);">
                           <children>
                              <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #334155; -fx-padding: 0 0 15 0;" text="📊 Content Breakdown" />
                              <PieChart fx:id="contentPieChart" prefHeight="250.0" />
                           </children>
                        </VBox>
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </content>
</ScrollPane>
