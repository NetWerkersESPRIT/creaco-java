<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER" spacing="22.0" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.post.BackofficeController">
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
    </padding>
    <children>
        <!-- Header Section -->
        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="top-nav">
            <children>
                <VBox>
                    <children>
                        <Label style="-fx-text-fill: #a0aec0; -fx-font-size: 12px;" text="Pages / Forum / Moderation" />
                        <Label styleClass="title-label" text="Post Moderation" />
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Button onAction="#logout" styleClass="btn-logout">
                            <graphic>
                                <Label style="-fx-text-fill: white; -fx-font-size: 16px;" text="🏃" />
                            </graphic>
                        </Button>
                    </children>
                </HBox>
            </children>
        </HBox>

        <!-- Main Moderation Card -->
        <VBox spacing="20.0" styleClass="card" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2d3748;" text="Pending Posts" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label style="-fx-text-fill: #718096; -fx-font-size: 13px;" text="Pending" />
                        <Button style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 8 15; -fx-text-fill: #4a5568; -fx-font-weight: bold;" text="🤖 Spam Filter" />
                    </children>
                </HBox>

                <Separator style="-fx-opacity: 0.3;" />

                <TableView fx:id="pendingTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="titleCol" prefWidth="300.0" text="TITLE" />
                        <TableColumn fx:id="authorCol" prefWidth="150.0" text="AUTHOR" />
                        <TableColumn fx:id="spamCol" prefWidth="120.0" text="SPAM SCORE" />
                        <TableColumn fx:id="dateCol" prefWidth="200.0" text="CREATED AT" />
                        <TableColumn fx:id="actionsCol" prefWidth="150.0" text="ACTIONS" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
</VBox>
