<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="400.0" prefWidth="350.0" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: #e2e8f0; -fx-border-radius: 15;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.forum.EmojiPickerModalController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
    <children>
        <HBox alignment="CENTER_LEFT">
            <children>
                <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Pick an Emoji" />
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#close" style="-fx-background-color: transparent; -fx-cursor: hand;" text="✕" />
            </children>
        </HBox>
        <TabPane fx:id="categoryTabPane" style="-fx-tab-min-width: 80;" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
            <tabs>
                <Tab text="😊">
                    <content>
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: transparent; -fx-background-color: transparent;">
                            <content>
                                <FlowPane fx:id="smileysGrid" hgap="5.0" vgap="5.0" prefWrapLength="320">
                                    <padding>
                                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                    </padding>
                                </FlowPane>
                            </content>
                        </ScrollPane>
                    </content>
                </Tab>
                <Tab text="🐱">
                    <content>
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: transparent; -fx-background-color: transparent;">
                            <content>
                                <FlowPane fx:id="animalsGrid" hgap="5.0" vgap="5.0" prefWrapLength="320">
                                    <padding>
                                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                    </padding>
                                </FlowPane>
                            </content>
                        </ScrollPane>
                    </content>
                </Tab>
                <Tab text="🍕">
                    <content>
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: transparent; -fx-background-color: transparent;">
                            <content>
                                <FlowPane fx:id="foodGrid" hgap="5.0" vgap="5.0" prefWrapLength="320">
                                    <padding>
                                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                    </padding>
                                </FlowPane>
                            </content>
                        </ScrollPane>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </children>
</VBox>
