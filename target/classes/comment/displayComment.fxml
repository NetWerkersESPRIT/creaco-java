<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="700.0" prefWidth="800.0" spacing="20.0" style="-fx-background-color: #ecf0f1; -fx-padding: 20;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.comment.DisplayCommentController">
    <children>
        <Button mnemonicParsing="false" onAction="#goBack" style="-fx-background-color: transparent; -fx-text-fill: #34495e; -fx-font-weight: bold;" text="&lt; Back to Posts" />
        <VBox spacing="5.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
            <children>
                <Label fx:id="postTitleLabel" text="Post Title" textFill="#2c3e50" wrapText="true">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>
                <Label fx:id="postContentLabel" text="Post content goes here..." textFill="#7f8c8d" wrapText="true">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
            </children>
        </VBox>
        
        <HBox alignment="CENTER_LEFT" spacing="20.0">
            <children>
                <Label text="Comments" textFill="#2c3e50">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>
                <VBox HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" onAction="#goAddComment" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15;" text="+ Add Comment" />
            </children>
        </HBox>
        
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
            <content>
                <VBox fx:id="commentsContainer" spacing="10.0" style="-fx-background-color: transparent; -fx-padding: 5;" />
            </content>
        </ScrollPane>
    </children>
</VBox>
