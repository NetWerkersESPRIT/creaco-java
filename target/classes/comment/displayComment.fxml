<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="22.0" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.comment.DisplayCommentController">
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
    </padding>
    <children>
        <HBox alignment="CENTER_LEFT" spacing="12.0">
            <children>
                <VBox spacing="6.0">
                    <children>
                        <Label style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #243b63;" text="Discussion Comments" />
                        <Label style="-fx-font-size: 14px; -fx-text-fill: #64748b;" text="Read and participate in the discussion." />
                        <Label fx:id="statusLabel" style="-fx-font-size: 13px; -fx-text-fill: #355388;" text="Loading comments..." />
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" onAction="#goBackToPosts" style="-fx-background-color: #e2e8f0; -fx-text-fill: #334155; -fx-background-radius: 12; -fx-font-weight: bold; -fx-padding: 10 16 10 16;" text="Back to Posts" />
            </children>
        </HBox>

        <!-- Current Post Display -->
        <VBox style="-fx-background-color: white; -fx-background-radius: 18; -fx-border-color: #dbe4f0; -fx-border-radius: 18;">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
            </padding>
            <children>
                <Label fx:id="postTitleLabel" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #243b63;" text="Post Title" wrapText="true" />
                <Label fx:id="postContentLabel" style="-fx-font-size: 15px; -fx-text-fill: #475569;" text="Post content..." wrapText="true">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </Label>
            </children>
        </VBox>

        <!-- Comments Section -->
        <VBox VBox.vgrow="ALWAYS" spacing="18.0" style="-fx-background-color: #f8fbff; -fx-background-radius: 18; -fx-border-color: #dbe4f0; -fx-border-radius: 18;">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #243b63;" text="Comments" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#goAddComment" style="-fx-background-color: #355388; -fx-text-fill: white; -fx-background-radius: 12; -fx-font-weight: bold; -fx-padding: 8 14 8 14;" text="+ Add Comment" />
                    </children>
                </HBox>
                <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" hbarPolicy="NEVER" pannable="true" style="-fx-background: transparent; -fx-background-color: transparent;">
                    <content>
                        <VBox fx:id="commentsContainer" spacing="12.0" style="-fx-background-color: transparent;">
                            <padding>
                                <Insets bottom="10.0" left="0.0" right="0.0" top="0.0" />
                            </padding>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </children>
</VBox>
