<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="700.0" prefWidth="800.0" spacing="20.0" style="-fx-background-color: #ecf0f1; -fx-padding: 30;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.comment.AddCommentController">
    <children>
        <Label text="Add New Comment" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>
        
        <Label fx:id="postTitleLabel" text="Replying to: [Post Title]" textFill="#7f8c8d">
            <font>
                <Font name="System Italic" size="14.0" />
            </font>
            <VBox.margin>
                <Insets bottom="10.0" />
            </VBox.margin>
        </Label>
        
        <VBox spacing="5.0">
            <Label text="Comment:" textFill="#34495e">
                <font>
                    <Font name="System Bold" size="14.0" />
                </font>
            </Label>
            <TextArea fx:id="bodyArea" prefHeight="150.0" promptText="Enter your comment..." style="-fx-font-size: 14px; -fx-padding: 10;" wrapText="true" />
        </VBox>
        
        <Button mnemonicParsing="false" onAction="#saveComment" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 10 20;" text="Save Comment" />
        <Button mnemonicParsing="false" onAction="#goBack" style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 10 20;" text="Cancel" />
    </children>
</VBox>
