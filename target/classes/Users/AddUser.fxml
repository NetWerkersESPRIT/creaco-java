<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20.0" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.UsersControllers.AddUserController" stylesheets="@../gui/styles.css">
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
    </padding>
    <children>
        <!-- Navbar -->
        <HBox styleClass="top-nav" alignment="CENTER_LEFT" spacing="20.0">
            <children>
                <VBox>
                    <Label style="-fx-text-fill: #a0aec0; -fx-font-size: 11px;" text="Pages / Admin / Users" />
                    <Label styleClass="title-label" text="Add New User" style="-fx-font-size: 20px;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#goBack" text="← Back to List" styleClass="btn-action-light" />
            </children>
        </HBox>

        <!-- Main Form Container -->
        <StackPane VBox.vgrow="ALWAYS">
            <children>
                <!-- Background Gradient Container -->
                <VBox prefHeight="250" maxHeight="250" style="-fx-background-color: linear-gradient(to right, #ce2d7c, #6c2db1, #3b82f6); -fx-background-radius: 20;" StackPane.alignment="TOP_CENTER" />
                
                <!-- White Form Card -->
                <VBox spacing="25.0" styleClass="card" maxWidth="600" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 40;">
                    <StackPane.margin>
                        <Insets top="60.0" />
                    </StackPane.margin>
                    <children>
                        <VBox spacing="5">
                            <Label text="User Registration" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2d3748;" />
                            <Label text="Enter credentials for the new content creator account" style="-fx-text-fill: #718096; -fx-font-size: 13px;" />
                        </VBox>
                        
                        <Separator style="-fx-opacity: 0.3;" />

                        <VBox spacing="15.0">
                            <children>
                                <VBox spacing="8.0">
                                    <children>
                                        <Label text="Username" style="-fx-font-weight: bold; -fx-text-fill: #4a5568; -fx-font-size: 12px;" />
                                        <TextField fx:id="txtUsername" promptText="Enter username" styleClass="search-bar" prefHeight="45" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0">
                                    <children>
                                        <Label text="Email Address" style="-fx-font-weight: bold; -fx-text-fill: #4a5568; -fx-font-size: 12px;" />
                                        <TextField fx:id="txtEmail" promptText="user@example.com" styleClass="search-bar" prefHeight="45" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0">
                                    <children>
                                        <Label text="Phone Number" style="-fx-font-weight: bold; -fx-text-fill: #4a5568; -fx-font-size: 12px;" />
                                        <TextField fx:id="txtNumtel" promptText="8-digit phone number" styleClass="search-bar" prefHeight="45" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0">
                                    <children>
                                        <Label text="Password" style="-fx-font-weight: bold; -fx-text-fill: #4a5568; -fx-font-size: 12px;" />
                                        <HBox alignment="CENTER_LEFT" spacing="10">
                                            <StackPane HBox.hgrow="ALWAYS">
                                                <PasswordField fx:id="txtPassword" promptText="••••••••" styleClass="search-bar" prefHeight="45" />
                                                <TextField fx:id="txtPasswordVisible" promptText="••••••••" styleClass="search-bar" prefHeight="45" visible="false" />
                                            </StackPane>
                                            <Button fx:id="btnTogglePassword" onAction="#togglePassword" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-text-fill: #718096; -fx-font-size: 18px;" text="👁" />
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <VBox spacing="15.0" style="-fx-padding: 10 0 0 0;">
                            <children>
                                <Button onAction="#saveUser" text="＋ CREATE ACCOUNT" prefHeight="50" maxWidth="Infinity" styleClass="btn-primary" />
                                <Button onAction="#goBack" text="RETURN TO CONNECTED USERS" prefHeight="50" maxWidth="Infinity" style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-text-fill: #718096; -fx-font-weight: bold; -fx-cursor: hand;" />
                            </children>
                        </VBox>
                        
                        <Label fx:id="lblMessage" wrapText="true" alignment="CENTER" maxWidth="Infinity" />
                    </children>
                </VBox>
            </children>
        </StackPane>
    </children>
</VBox>