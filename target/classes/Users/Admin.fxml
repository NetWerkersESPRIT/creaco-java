<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="760.0" prefWidth="1280.0" styleClass="main-container" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.UsersControllers.AdminController" stylesheets="@../gui/styles.css">
    <left>
        <VBox prefWidth="260.0" spacing="20.0" styleClass="sidebar">
            <padding>
                <Insets bottom="30.0" left="24.0" right="24.0" top="30.0" />
            </padding>
            <children>
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <Label styleClass="sidebar-brand" text="CreaCo" />
                </HBox>
                
                <Label styleClass="section-header" text="ADMIN" />
                <VBox spacing="10.0">
                    <Button mnemonicParsing="false" onAction="#goBack" prefWidth="210.0" styleClass="sidebar-item">
                        <graphic>
                            <HBox spacing="15.0" alignment="CENTER_LEFT">
                                <StackPane styleClass="sidebar-icon-box">
                                    <Label text="🏠" style="-fx-font-size: 16px;" />
                                </StackPane>
                                <Label text="Dashboard" />
                            </HBox>
                        </graphic>
                    </Button>
                    <Button mnemonicParsing="false" prefWidth="210.0" styleClass="sidebar-item, sidebar-item-active">
                        <graphic>
                            <HBox spacing="15.0" alignment="CENTER_LEFT">
                                <StackPane styleClass="sidebar-icon-box" style="-fx-background-color: -fx-primary-pink;">
                                    <Label text="🛠" style="-fx-font-size: 16px; -fx-text-fill: white;" />
                                </StackPane>
                                <Label text="Users Management" style="-fx-text-fill: -fx-primary-pink;"/>
                            </HBox>
                        </graphic>
                    </Button>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />
                <Button onAction="#goBack" text="← Back" prefHeight="45.0" prefWidth="210.0" styleClass="btn-primary" style="-fx-background-color: #2d3748;"/>
            </children>
        </VBox>
    </left>
    <center>
        <VBox spacing="22.0">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
            </padding>
            <children>
                <HBox styleClass="top-nav" alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <VBox>
                            <Label style="-fx-text-fill: #a0aec0; -fx-font-size: 12px;" text="Admin / System" />
                            <Label styleClass="title-label" text="Admin Panel" />
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#handleAddUser" prefHeight="44.0" styleClass="btn-primary" text="＋ Add New User" />
                    </children>
                </HBox>

                <VBox VBox.vgrow="ALWAYS" styleClass="card" spacing="15">
                    <children>
                        <VBox spacing="5">
                            <Label text="Users Table" styleClass="card-title" />
                            <Label text="Manage user accounts, roles, and permissions" styleClass="card-subtitle" />
                        </VBox>
                        <Separator />
                        <TableView fx:id="usersTable" VBox.vgrow="ALWAYS" style="-fx-background-radius: 12; -fx-border-radius: 12;">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                                <TableColumn fx:id="colUsername" prefWidth="150.0" text="USERNAME" />
                                <TableColumn fx:id="colEmail" prefWidth="200.0" text="EMAIL" />
                                <TableColumn fx:id="colRole" prefWidth="120.0" text="ROLE" />
                                <TableColumn fx:id="colNumtel" prefWidth="120.0" text="PHONE" />
                                <TableColumn fx:id="colPoints" prefWidth="80.0" text="POINTS" />
                                <TableColumn fx:id="colActions" prefWidth="180.0" text="ACTIONS" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>