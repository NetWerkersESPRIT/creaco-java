<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="760.0" prefWidth="1280.0"
            style="-fx-background-color: #edf3fb;"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gui.FrontMainController">

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox prefWidth="220.0" spacing="18.0"
              style="-fx-background-color: #1f365c;">
            <padding>
                <Insets top="30" left="20" right="20" bottom="30"/>
            </padding>

            <children>
                <Label text="Creaco"
                       style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;" />

                <Label text="Explore courses"
                       style="-fx-text-fill: #b8c7df; -fx-font-size: 13px;" />

                <Button text="All Courses"
                        prefHeight="48" prefWidth="180"
                        style="-fx-background-color: #f59e0b; -fx-text-fill: #1f365c; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 14;" />
                <Region VBox.vgrow="ALWAYS" />
                <Button onAction="#logout" text="Log Out" prefHeight="48.0" prefWidth="180.0" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;" />
            </children>
        </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="22.0">

            <padding>
                <Insets top="24" left="24" right="24" bottom="24"/>
            </padding>

            <children>
                <!-- PREVIEW BANNER -->
                <HBox fx:id="previewBanner" alignment="CENTER_LEFT" spacing="15" visible="false" managed="false"
                      style="-fx-background-color: #fef08a; -fx-padding: 12 24; -fx-background-radius: 8;">
                    <Label text="You are now in preview mode" style="-fx-font-weight: bold; -fx-text-fill: #854d0e; -fx-font-size: 14;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="Exit Preview" onAction="#exitPreview"
                            style="-fx-background-color: #ca8a04; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6;" />
                </HBox>

                <!-- HEADER -->
                <HBox alignment="CENTER_LEFT" spacing="12">

                    <children>

                        <VBox spacing="6">
                            <children>
                                <Label text="Courses"
                                       style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #243b63;" />

                                <Label text="Browse and open available courses"
                                       style="-fx-font-size: 14px; -fx-text-fill: #64748b;" />
                            </children>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <!-- ✅ SEARCH FIELD ADDED -->
                        <TextField fx:id="searchField"
                                   promptText="Search courses..."
                                   prefWidth="280"
                                   style="-fx-background-radius: 10; -fx-padding: 8;" />

                    </children>
                </HBox>

                <!-- COURSES LIST -->
                <ScrollPane fitToWidth="true"
                            hbarPolicy="NEVER"
                            style="-fx-background: transparent; -fx-background-color: transparent;"
                            VBox.vgrow="ALWAYS">

                    <content>
                        <TilePane fx:id="coursesContainer"
                                  hgap="20"
                                  vgap="20"
                                  prefColumns="3"
                                  prefTileWidth="300"
                                  tileAlignment="TOP_LEFT"
                                  style="-fx-padding: 10;">
                        </TilePane>
                    </content>

                </ScrollPane>

            </children>
        </VBox>
    </center>

</BorderPane>