<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="760.0" prefWidth="1280.0" styleClass="main-container"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gui.FrontMainController">


    <left>
        <VBox prefWidth="240.0" spacing="25.0" styleClass="sidebar" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="30.0" left="24.0" right="24.0" top="30.0" />
            </padding>
            <children>
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <Label styleClass="sidebar-brand" text="CreaCo" />
                </HBox>
                
                <VBox spacing="12.0">
                    <Button mnemonicParsing="false" prefWidth="210.0" styleClass="sidebar-item, sidebar-item-active">
                        <graphic>
                            <HBox spacing="15.0" alignment="CENTER_LEFT">
                                <StackPane styleClass="sidebar-icon-box">
                                    <Label text="🏠" style="-fx-font-size: 16px;" />
                                </StackPane>
                                <Label text="Dashboard" />
                            </HBox>
                        </graphic>
                    </Button>
                </VBox>

                <Label styleClass="section-header" text="WORKFLOW MANAGEMENT" />
                <VBox spacing="10.0">
                    <Button mnemonicParsing="false" prefWidth="210.0" styleClass="sidebar-item">
                        <graphic>
                            <HBox spacing="15.0" alignment="CENTER_LEFT">
                                <StackPane styleClass="sidebar-icon-box">
                                    <Label text="🎓" style="-fx-font-size: 16px;" />
                                </StackPane>
                                <Label text="Courses" />
                            </HBox>
                        </graphic>
                    </Button>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />
                <Button onAction="#logout" text="Log Out" prefHeight="45.0" prefWidth="200.0" styleClass="btn-primary" />
            </children>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" style="-fx-background: transparent; -fx-background-color: transparent;">
            <content>
                <VBox spacing="22.0" style="-fx-background-color: transparent;">
                    <padding>
                        <Insets top="24" left="24" right="24" bottom="24"/>
                    </padding>
                    <children>
                        <HBox fx:id="previewBanner" alignment="CENTER_LEFT" spacing="15" visible="false" managed="false"
                              style="-fx-background-color: #fef08a; -fx-padding: 12 24; -fx-background-radius: 8;">
                            <Label text="You are now in preview mode" style="-fx-font-weight: bold; -fx-text-fill: #854d0e; -fx-font-size: 14;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button text="Exit Preview" onAction="#exitPreview"
                                    style="-fx-background-color: #ca8a04; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6;" />
                        </HBox>

                        <HBox styleClass="top-nav" alignment="CENTER_LEFT" spacing="15.0">
                            <children>
                                <VBox>
                                    <Label style="-fx-text-fill: #a0aec0; -fx-font-size: 12px;" text="Pages / Dashboard" />
                                    <Label styleClass="title-label" text="Explore" />
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <TextField fx:id="searchField" promptText="Search courses..." styleClass="search-bar" prefWidth="280.0" />
                                <Button onAction="#logout" styleClass="btn-logout">
                                    <graphic>
                                        <Label text="🏃" style="-fx-text-fill: white; -fx-font-size: 16px;" />
                                    </graphic>
                                </Button>
                            </children>
                        </HBox>

                        <VBox spacing="20.0" VBox.vgrow="ALWAYS">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <Label text="Featured courses" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: -fx-text-main;" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Button text="See all →" style="-fx-background-color: #2d3748; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 16; -fx-font-weight: bold;" />
                                </HBox>

                                <ScrollPane fitToHeight="true" vbarPolicy="NEVER" hbarPolicy="AS_NEEDED" style="-fx-background: transparent; -fx-background-color: transparent;">
                                    <content>
                                        <HBox fx:id="coursesContainer" spacing="24.0" style="-fx-padding: 10 0;">
                                            <!-- Cards will be injected here -->
                                        </HBox>
                                    </content>
                                </ScrollPane>

                                <Separator style="-fx-padding: 10 0;" />

                                <!-- Help-Desk Section -->
                                <VBox spacing="20.0">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                                            <Label text="My help-desk requests" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: -fx-text-main;" />
                                            <Region HBox.hgrow="ALWAYS" />
                                            <Button onAction="#onRequestHelp" text="+ New request" style="-fx-background-color: #1a1a1a; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 20; -fx-font-weight: bold;" />
                                        </HBox>

                                        <HBox spacing="10.0">
                                            <children>
                                                <Button fx:id="btnFilterAll" onAction="#filterAllTickets" text="All" styleClass="btn-secondary" style="-fx-background-color: #1a1a1a; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 6 20;" />
                                                <Button fx:id="btnFilterPending" onAction="#filterPendingTickets" text="Pending" styleClass="btn-secondary" style="-fx-background-color: transparent; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 6 20;" />
                                            </children>
                                        </HBox>

                                        <VBox fx:id="ticketsContainer" spacing="15.0">
                                            <!-- Ticket cards will be injected here -->
                                        </VBox>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>