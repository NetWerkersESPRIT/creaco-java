<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="gui.ChooseRoleController"
            prefHeight="400.0" prefWidth="600.0"
            styleClass="main-container">

    <children>
        <VBox alignment="CENTER" spacing="20.0"
              AnchorPane.topAnchor="0.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0">

            <Label text="Choose Your Role"
                   styleClass="title-label" />

            <Label text="Please select how you want to continue"
                   styleClass="subtitle-label" />

            <Button text="I'm an Admin"
                    onAction="#handleAdmin"
                    prefWidth="220"
                    prefHeight="45"
                    styleClass="btn-primary" />

            <Button text="I'm a Content Creator"
                    onAction="#handleCreator"
                    prefWidth="220"
                    prefHeight="45"
                    styleClass="btn"
                    style="-fx-background-color: white; -fx-text-fill: #2d3748; -fx-border-color: #e2e8f0; -fx-border-radius: 12;" />

        </VBox>
    </children>
</AnchorPane>