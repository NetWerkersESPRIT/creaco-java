<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="gui.ChooseRoleController"
            prefHeight="400.0" prefWidth="600.0"
            style="-fx-background-color: #f5f5f5;">

    <children>
        <VBox alignment="CENTER" spacing="20.0"
              AnchorPane.topAnchor="0.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0">

            <Label text="Choose Your Role"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #333;" />

            <Label text="Please select how you want to continue"
                   style="-fx-font-size: 14px; -fx-text-fill: #777;" />

            <Button text="I'm an Admin"
                    onAction="#handleAdmin"
                    prefWidth="200"
                    prefHeight="40"
                    style="-fx-background-color: #2c7be5; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 8;" />

            <Button text="I'm a Content Creator"
                    onAction="#handleCreator"
                    prefWidth="200"
                    prefHeight="40"
                    style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 8;" />

        </VBox>
    </children>
</AnchorPane>