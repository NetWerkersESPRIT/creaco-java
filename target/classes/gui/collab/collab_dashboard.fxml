<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="25.0" styleClass="main-container" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.collab.CollabDashboardController">
    <stylesheets>
        <URL value="@../styles.css" />
    </stylesheets>
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
    <children>
        <!-- Hero Banner -->
        <VBox styleClass="hero-banner">
            <children>
                <StackPane VBox.vgrow="ALWAYS" styleClass="hero-overlay">
                    <children>
                        <HBox alignment="BOTTOM_LEFT">
                            <children>
                                <VBox styleClass="hero-content-box">
                                    <children>
                                        <Label styleClass="hero-title" text="Strategic Partners Network" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </StackPane>
            </children>
        </VBox>

        <!-- Tabs -->
        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <children>
                <HBox styleClass="tab-container">
                    <children>
                        <Button fx:id="btnPartners" styleClass="tab-btn" text="📂 Partners" onAction="#showPartners" />
                        <Button fx:id="btnRequests" styleClass="tab-btn" text="🕊 My Requests" onAction="#showRequests" />
                        <Button fx:id="btnContracts" styleClass="tab-btn" text="📋 My Contracts" onAction="#showContracts" />
                    </children>
                </HBox>
            </children>
        </HBox>

        <!-- Main Content Area where lists will be loaded -->
        <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS" />
    </children>
</VBox>
