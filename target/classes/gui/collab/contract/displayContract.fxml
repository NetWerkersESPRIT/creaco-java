<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="25.0" VBox.vgrow="ALWAYS" styleClass="main-container" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.collab.contract.DisplayContractController">
    <stylesheets>
        <URL value="@../../styles.css" />
    </stylesheets>
    <children>
        <!-- Main Content Card -->
        <VBox VBox.vgrow="ALWAYS" styleClass="card">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
            <children>
                <!-- Card Header -->
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <Label styleClass="card-title" text="Manage my contracts" />
                        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="search-bar" maxWidth="350">
                            <children>
                                <Label text="🔍" style="-fx-text-fill: -fx-text-muted; -fx-font-size: 14px;" />
                                <TextField fx:id="contractSearchField" promptText="Search #, title, partner..."
                                           style="-fx-background-color: transparent; -fx-padding: 0; -fx-font-size: 13px;" HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Label style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-font-weight: bold;" text="STATUS:" />
                                <ComboBox fx:id="statusFilter" prefWidth="150" promptText="All Statuses" styleClass="combo-simple" />
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <!-- Column Headers -->
                <HBox spacing="10.0" style="-fx-padding: 30 0 15 0; -fx-border-color: transparent transparent #f1f5f9 transparent; -fx-border-width: 0 0 1 0;">
                    <children>
                        <Label prefWidth="300" styleClass="list-header-label" text="CONTRACT NUMBER" />
                        <Label prefWidth="200" styleClass="list-header-label" text="DOMAIN" />
                        <Label prefWidth="150" styleClass="list-header-label" text="STATUS" />
                        <Label prefWidth="200" styleClass="list-header-label" text="EFFECTIVE DATE" />
                        <Region HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>

                <!-- Contracts List -->
                <ListView fx:id="contractsListView" VBox.vgrow="ALWAYS" minHeight="500.0" prefHeight="600.0"
                          style="-fx-background-color: transparent; -fx-background: transparent; -fx-padding: 10 0 0 0;"/>
            </children>
        </VBox>
    </children>
</VBox>
