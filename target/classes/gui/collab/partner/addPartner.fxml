<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>

<VBox styleClass="main-container" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.collab.partner.AddPartnerController">
    <stylesheets>
        <URL value="@../../styles.css" />
    </stylesheets>
    <children>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
            <content>
                <VBox spacing="35.0">
                    <padding>
                        <Insets bottom="50.0" left="50.0" right="50.0" top="40.0" />
                    </padding>
                    <children>
                        <!-- Header Section -->
                        <VBox spacing="10.0">
                            <children>
                                <Label styleClass="title-label" text="Collaborator Information" />
                                <Label styleClass="subtitle-label" text="Enter details to register a new strategic partner." />
                            </children>
                        </VBox>

                        <!-- Form Card -->
                        <VBox spacing="25.0" styleClass="card" maxWidth="900">
                            <children>
                                <HBox spacing="25.0">
                                    <children>
                                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                            <Label styleClass="form-label" text="Company Name" />
                                            <TextField fx:id="pCompanyField" promptText="Enter company name" />
                                            <Label fx:id="pCompanyError" managed="false" textFill="#e11d48" visible="false" style="-fx-font-size: 11px;" />
                                        </VBox>
                                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                            <Label styleClass="form-label" text="Name" />
                                            <TextField fx:id="pNameField" promptText="Primary contact name" />
                                            <Label fx:id="pNameError" managed="false" textFill="#e11d48" visible="false" style="-fx-font-size: 11px;" />
                                        </VBox>
                                    </children>
                                </HBox>

                                <HBox spacing="25.0">
                                    <children>
                                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                            <Label styleClass="form-label" text="Email Address" />
                                            <TextField fx:id="pEmailField" promptText="example@company.com" />
                                            <Label fx:id="pEmailError" managed="false" textFill="#e11d48" visible="false" style="-fx-font-size: 11px;" />
                                        </VBox>
                                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                            <Label styleClass="form-label" text="Phone" />
                                            <TextField fx:id="pPhoneField" promptText="+216 -- --- ---" />
                                        </VBox>
                                    </children>
                                </HBox>

                                <VBox spacing="8.0">
                                    <children>
                                        <Label styleClass="form-label" text="Domain" />
                                        <TextField fx:id="pDomainField" promptText="e.g.: Marketing, Tech, Finance" />
                                    </children>
                                </VBox>

                                <VBox spacing="8.0">
                                    <children>
                                        <Label styleClass="form-label" text="Address" />
                                        <TextArea fx:id="pAddressArea" prefRowCount="2" promptText="Physical address of the company" wrapText="true" />
                                    </children>
                                </VBox>

                                <HBox spacing="25.0">
                                    <children>
                                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                            <Label styleClass="form-label" text="Website" />
                                            <TextField fx:id="pWebsiteField" promptText="https://www.example.com" />
                                            <Label fx:id="pWebsiteError" managed="false" textFill="#e11d48" visible="false" style="-fx-font-size: 11px;" />
                                        </VBox>
                                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                            <Label styleClass="form-label" text="Logo (Image file)" />
                                            <HBox styleClass="file-input-container">
                                                <children>
                                                    <Button onAction="#onBrowseLogo" styleClass="file-input-btn" text="Choose File" />
                                                    <TextField fx:id="pLogoField" editable="false" promptText="No file chosen" styleClass="file-input-text" HBox.hgrow="ALWAYS" />
                                                </children>
                                            </HBox>
                                        </VBox>
                                    </children>
                                </HBox>

                                <VBox spacing="8.0">
                                    <children>
                                        <Label styleClass="form-label" text="Description" />
                                        <TextArea fx:id="pDescArea" prefRowCount="4" promptText="Tell us more about this partnership..." wrapText="true" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <!-- Actions Section -->
                        <HBox alignment="CENTER_RIGHT" spacing="20.0" maxWidth="900">
                            <children>
                                <Button onAction="#onCancelPartner" styleClass="btn-cancel" text="CANCEL" />
                                <Button onAction="#onSavePartner" prefWidth="120.0" prefHeight="45.0" styleClass="btn-primary" text="SAVE" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>
