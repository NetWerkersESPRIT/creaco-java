<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="760.0" prefWidth="1280.0" styleClass="main-container"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gui.FrontResourceController" stylesheets="@styles.css">

    <left>
        <VBox prefWidth="240.0" spacing="25.0" styleClass="sidebar" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="30.0" left="24.0" right="24.0" top="30.0" />
            </padding>
            <children>
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <Label styleClass="sidebar-brand" text="CreaCo" />
                </HBox>
                
                <VBox spacing="12.0">
                    <Button mnemonicParsing="false" onAction="#goBack" prefWidth="210.0" styleClass="sidebar-item">
                        <graphic>
                            <HBox spacing="15.0" alignment="CENTER_LEFT">
                                <StackPane styleClass="sidebar-icon-box">
                                    <Label text="🏠" style="-fx-font-size: 16px;" />
                                </StackPane>
                                <Label text="Dashboard" />
                            </HBox>
                        </graphic>
                    </Button>
                </VBox>

                <Label styleClass="section-header" text="WORKFLOW MANAGEMENT" />
                <VBox spacing="10.0">
                    <Button mnemonicParsing="false" onAction="#goBack" prefWidth="210.0" styleClass="sidebar-item, sidebar-item-active">
                        <graphic>
                            <HBox spacing="15.0" alignment="CENTER_LEFT">
                                <StackPane styleClass="sidebar-icon-box-active">
                                    <Label text="🎓" style="-fx-font-size: 16px; -fx-text-fill: white;" />
                                </StackPane>
                                <Label text="Courses" />
                            </HBox>
                        </graphic>
                    </Button>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />
            </children>
        </VBox>
    </left>

    <center>
        <VBox spacing="22.0">
            <padding>
                <Insets top="24" left="24" right="24" bottom="24"/>
            </padding>
            <children>
                <HBox fx:id="previewBanner" alignment="CENTER_LEFT" spacing="15" visible="false" managed="false"
                      style="-fx-background-color: #fef08a; -fx-padding: 12 24; -fx-background-radius: 8;">
                    <Label text="You are now in preview mode" style="-fx-font-weight: bold; -fx-text-fill: #854d0e; -fx-font-size: 14;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="Exit Preview" onAction="#exitPreview"
                            style="-fx-background-color: #ca8a04; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6;" />
                </HBox>

                <HBox styleClass="top-nav" alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <VBox>
                            <Label style="-fx-text-fill: #a0aec0; -fx-font-size: 12px;" text="Pages / Courses / Resources" />
                            <Label fx:id="courseTitleLabel" styleClass="title-label" text="Resources" style="-fx-font-size: 20px;"/>
                        </VBox>
                        
                        <Region HBox.hgrow="ALWAYS" />
                        
                        <HBox alignment="CENTER" spacing="12" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 5 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 4);">
                            <children>
                                <VBox alignment="CENTER_RIGHT">
                                    <Label text="Welcome" style="-fx-text-fill: -fx-primary-pink; -fx-font-size: 10px; -fx-font-weight: bold;" />
                                    <Label fx:id="lblNavUsername" text="User" style="-fx-text-fill: -fx-text-main; -fx-font-weight: bold; -fx-font-size: 14px;" />
                                </VBox>
                                <Label fx:id="lblNavUserRole" text="USER" styleClass="badge-pink" style="-fx-font-size: 9px; -fx-padding: 2 8;"/>
                            </children>
                        </HBox>

                        <Button onAction="#logout" styleClass="btn-logout" prefHeight="40" prefWidth="40">
                            <graphic>
                                <Label text="🏃" style="-fx-text-fill: white; -fx-font-size: 16px;" />
                            </graphic>
                        </Button>
                    </children>
                </HBox>

                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: transparent; -fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                    <content>
                        <TilePane fx:id="resourcesContainer" hgap="24" vgap="24" prefColumns="3" prefTileWidth="300" tileAlignment="TOP_LEFT" style="-fx-padding: 10;" />
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </center>

</BorderPane>
