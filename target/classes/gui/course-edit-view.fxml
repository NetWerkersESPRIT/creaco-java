<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="760.0" prefWidth="1280.0" style="-fx-background-color: #edf3fb;"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gui.CourseFormController">
    <left>
        <VBox prefWidth="220.0" spacing="18.0" style="-fx-background-color: #1f365c;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="30.0" left="20.0" right="20.0" top="30.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT">
                    <Label style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;" text="Creaco" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button onAction="#goToPreview" text="Preview" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" />
                </HBox>
                <Label style="-fx-text-fill: #b8c7df; -fx-font-size: 13px;" text="Course management" />
                <Button mnemonicParsing="false" prefHeight="48.0" prefWidth="180.0"
                        style="-fx-background-color: #f59e0b; -fx-text-fill: #1f365c; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 14;"
                        text="Courses" />
                <Region VBox.vgrow="ALWAYS" />
                <Button onAction="#logout" text="Logout" prefHeight="48.0" prefWidth="180.0" style="-fx-background-color: #374151; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 14; -fx-cursor: hand;" />
            </children>
        </VBox>
    </left>
    <fx:define>
        <ToggleGroup fx:id="statusToggleGroup" />
    </fx:define>
    <center>
        <VBox alignment="TOP_CENTER" spacing="24.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="28.0" left="28.0" right="28.0" top="28.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <VBox spacing="6.0">
                            <children>
                                <Label fx:id="titleLabel"
                                       style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #243b63;"
                                       text="Edit Course" />
                                <Label fx:id="subtitleLabel" style="-fx-font-size: 14px; -fx-text-fill: #64748b;"
                                       text="Update the selected course." />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>
                <VBox maxWidth="860.0" spacing="22.0"
                      style="-fx-background-color: white; -fx-background-radius: 18; -fx-border-color: #dbe4f0; -fx-border-radius: 18;">
                    <padding>
                        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                    </padding>
                    <children>
                        <GridPane hgap="18.0" vgap="18.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" percentWidth="50.0" />
                                <ColumnConstraints hgrow="SOMETIMES" percentWidth="50.0" />
                            </columnConstraints>
                            <children>
                                <VBox spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <children>
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #334155;" text="Title *" />
                                        <TextField fx:id="titleField" promptText="Course title" />
                                        <Label fx:id="titleErrorLabel" text="" style="-fx-text-fill: #b91c1c; -fx-font-size: 12px;" visible="false" managed="false" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <children>
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #334155;" text="Category *" />
                                        <ComboBox fx:id="categoryCombo" promptText="Select category" />
                                        <Label fx:id="categoryErrorLabel" text="" style="-fx-text-fill: #b91c1c; -fx-font-size: 12px;" visible="false" managed="false" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                    <children>
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #334155;" text="Status *" />
                                        <HBox spacing="12.0">
                                            <children>
                                                <RadioButton fx:id="publishedRadio" toggleGroup="$statusToggleGroup" selected="true" text="Published" />
                                                <RadioButton fx:id="draftRadio" toggleGroup="$statusToggleGroup" text="Draft" />
                                            </children>
                                        </HBox>
                                        <Label fx:id="statusErrorLabel" text="" style="-fx-text-fill: #b91c1c; -fx-font-size: 12px;" visible="false" managed="false" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                    <children>
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #334155;" text="Level *" />
                                        <ComboBox fx:id="levelCombo" promptText="Select level" />
                                        <Label fx:id="levelErrorLabel" text="" style="-fx-text-fill: #b91c1c; -fx-font-size: 12px;" visible="false" managed="false" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                    <children>
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #334155;" text="Estimated duration (min)" />
                                        <TextField fx:id="durationField" promptText="25" />
                                        <Label fx:id="durationErrorLabel" text="" style="-fx-text-fill: #b91c1c; -fx-font-size: 12px;" visible="false" managed="false" />
                                    </children>
                                </VBox>
                            </children>
                        </GridPane>
                        <VBox spacing="8.0">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-text-fill: #334155;" text="Description" />
                                <TextArea fx:id="descriptionArea" prefHeight="220.0" promptText="Describe this course..." wrapText="true" />
                            </children>
                        </VBox>
                        <HBox alignment="CENTER_RIGHT" spacing="12.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#onCancel"
                                        style="-fx-background-color: #3f5f98; -fx-text-fill: white; -fx-background-radius: 18; -fx-padding: 10 18 10 18; -fx-font-size: 14px; -fx-font-weight: bold;"
                                        text="Cancel" />
                                <Button mnemonicParsing="false" onAction="#onSave"
                                        style="-fx-background-color: #3f5f98; -fx-text-fill: white; -fx-background-radius: 18; -fx-padding: 10 18 10 18; -fx-font-size: 14px; -fx-font-weight: bold;"
                                        text="Save course" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>
