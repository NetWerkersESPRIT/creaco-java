<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="760.0" prefWidth="1280.0" style="-fx-background-color: #edf3fb;"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gui.MainController">
    <left>
        <VBox prefWidth="220.0" spacing="18.0" style="-fx-background-color: #1f365c;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="30.0" left="20.0" right="20.0" top="30.0" />
            </padding>
            <children>
                <Label style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;" text="Creaco" />
                <Button fx:id="forumNavButton" mnemonicParsing="false" onAction="#showForum" prefHeight="48.0" prefWidth="180.0" text="Forum" />
                <Button fx:id="coursesNavButton" mnemonicParsing="false" onAction="#showCourses" prefHeight="48.0" prefWidth="180.0" text="Courses" visible="false" managed="false" />
            </children>
        </VBox>
    </left>
    <center>
        <VBox spacing="22.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <VBox spacing="6.0">
                            <children>
                                <Label fx:id="pageTitleLabel"
                                       style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #243b63;"
                                       text="Forum" />
                                <Label fx:id="pageSubtitleLabel" style="-fx-font-size: 14px; -fx-text-fill: #64748b;"
                                       text="Create posts, review discussions, and manage comments." />
                                <Label fx:id="statusLabel" style="-fx-font-size: 13px; -fx-text-fill: #355388;"
                                       text="Loading data..." />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <!-- Forum Section -->
                <VBox fx:id="forumSection" spacing="22.0" VBox.vgrow="ALWAYS">
                    <children>
                        <!-- Add Post Form -->
                        <VBox spacing="22.0" maxWidth="980.0"
                              style="-fx-background-color: white; -fx-background-radius: 18; -fx-border-color: #dbe4f0; -fx-border-radius: 18;">
                            <padding>
                                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                            </padding>
                            <children>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <VBox spacing="6.0">
                                            <children>
                                                <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #243b63;"
                                                       text="Add Post" />
                                                <Label style="-fx-font-size: 14px; -fx-text-fill: #64748b;"
                                                       text="Create a new discussion post." />
                                            </children>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Button fx:id="cancelEditButton" mnemonicParsing="false" onAction="#onCancelEdit"
                                                style="-fx-background-color: #e2e8f0; -fx-text-fill: #334155; -fx-background-radius: 12; -fx-font-weight: bold;"
                                                text="Cancel edit" />
                                    </children>
                                </HBox>
                                <VBox spacing="8.0">
                                    <children>
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #334155;" text="Title" />
                                        <TextField fx:id="postTitleField" promptText="Post title" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0">
                                    <children>
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #334155;" text="Content" />
                                        <TextArea fx:id="postContentArea" prefHeight="140.0" promptText="Write your post..." wrapText="true" />
                                    </children>
                                </VBox>
                                <HBox alignment="CENTER_RIGHT" spacing="12.0">
                                    <children>
                                        <Button fx:id="submitPostButton" mnemonicParsing="false" onAction="#onSubmitPost"
                                                style="-fx-background-color: #355388; -fx-text-fill: white; -fx-background-radius: 12; -fx-font-weight: bold;"
                                                text="Add post" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <!-- Posts List -->
                        <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" hbarPolicy="NEVER" pannable="true"
                                    style="-fx-background: transparent; -fx-background-color: transparent;">
                            <content>
                                <VBox fx:id="postsContainer" spacing="16.0">
                                    <padding>
                                        <Insets bottom="12.0" left="0.0" right="0.0" top="0.0" />
                                    </padding>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>

                <!-- Courses Section (hidden) -->
                <VBox fx:id="coursesSection" spacing="18.0" visible="false" managed="false">
                    <children>
                        <Label text="Courses section is disabled" style="-fx-font-size: 16px; -fx-text-fill: #64748b;" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>