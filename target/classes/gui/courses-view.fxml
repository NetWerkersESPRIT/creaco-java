<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.*?>

<VBox fx:id="coursesView" spacing="22.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.CoursesController">
    <padding>
        <Insets top="24" left="24" right="24" bottom="24"/>
    </padding>
    <children>
        <!-- Dashboard Header Section -->
        <GridPane hgap="22.0">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="72.0" />
                <ColumnConstraints hgrow="ALWAYS" percentWidth="28.0" />
            </columnConstraints>
            <children>
                <!-- Workshop Discovery Card -->
                <VBox styleClass="card" GridPane.columnIndex="0">
                    <children>
                        <VBox spacing="5.0">
                            <Label text="Discover our workshops" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -fx-text-main;" />
                            <Label text="Choose a category to explore available courses and resources." styleClass="subtitle-label" />
                        </VBox>
                        <HBox spacing="15.0" alignment="CENTER_LEFT">
                            <TextField fx:id="searchField" promptText="Rechercher" styleClass="search-bar" HBox.hgrow="ALWAYS" />
                            <HBox fx:id="boxAdminActions" spacing="10.0">
                                <children>
                                    <Button text="Manage Categories" onAction="#onManageCategories" styleClass="btn-primary" prefHeight="45.0" />
                                    <Button text="+ Add Course" onAction="#onAddCourse" styleClass="btn-primary" prefHeight="45.0" style="-fx-background-color: #2d3748; -fx-text-fill: white;" />
                                </children>
                            </HBox>
                        </HBox>
                    </children>
                </VBox>

                <!-- Mentoring Support Card -->
                <VBox styleClass="mentoring-card" spacing="15.0" GridPane.columnIndex="1">
                    <children>
                        <HBox spacing="10.0" alignment="CENTER_LEFT">
                            <Label text="🤝" style="-fx-font-size: 20px;" />
                            <Label text="Mentoring Support" styleClass="mentoring-title" />
                        </HBox>
                        <Label text="You have pending questions from creators." wrapText="true" styleClass="mentoring-subtitle" />
                        <Button text="View Questions" onAction="#onViewQuestions" prefWidth="Infinity" styleClass="btn-mentoring" />
                    </children>
                </VBox>
            </children>
        </GridPane>

        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    style="-fx-background: transparent; -fx-background-color: transparent;"
                    VBox.vgrow="ALWAYS">
            <content>
                <FlowPane fx:id="coursesContainer"
                          hgap="24.0"
                          vgap="24.0"
                          prefWrapLength="1000"
                          alignment="TOP_LEFT"
                          style="-fx-padding: 10 5;">
                </FlowPane>
            </content>
        </ScrollPane>
    </children>
</VBox>
