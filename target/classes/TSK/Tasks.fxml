<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="760.0" prefWidth="1280.0" styleClass="main-container" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.TSKControllers.TasksController" stylesheets="@../gui/styles.css">
    <left>
        <VBox prefWidth="260.0" spacing="20.0" styleClass="sidebar">
            <padding>
                <Insets bottom="30.0" left="24.0" right="24.0" top="30.0" />
            </padding>
            <children>
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <Label styleClass="sidebar-brand" text="CreaCo" />
                </HBox>
                
                <Label styleClass="section-header" text="NAVIGATION" />
                <VBox spacing="10.0">
                    <Button mnemonicParsing="false" onAction="#goBack" prefWidth="210.0" styleClass="sidebar-item">
                        <graphic>
                            <HBox spacing="15.0" alignment="CENTER_LEFT">
                                <StackPane styleClass="sidebar-icon-box">
                                    <Label text="🏠" style="-fx-font-size: 16px;" />
                                </StackPane>
                                <Label text="Dashboard" />
                            </HBox>
                        </graphic>
                    </Button>
                    <Button mnemonicParsing="false" onAction="#goToIdea" prefWidth="210.0" styleClass="sidebar-item">
                        <graphic>
                            <HBox spacing="15.0" alignment="CENTER_LEFT">
                                <StackPane styleClass="sidebar-icon-box">
                                    <Label text="💡" style="-fx-font-size: 16px;" />
                                </StackPane>
                                <Label text="Ideas" />
                            </HBox>
                        </graphic>
                    </Button>
                    <Button mnemonicParsing="false" onAction="#goToMission" prefWidth="210.0" styleClass="sidebar-item">
                        <graphic>
                            <HBox spacing="15.0" alignment="CENTER_LEFT">
                                <StackPane styleClass="sidebar-icon-box">
                                    <Label text="🎯" style="-fx-font-size: 16px;" />
                                </StackPane>
                                <Label text="Missions" />
                            </HBox>
                        </graphic>
                    </Button>
                    <Button mnemonicParsing="false" prefWidth="210.0" styleClass="sidebar-item, sidebar-item-active">
                        <graphic>
                            <HBox spacing="15.0" alignment="CENTER_LEFT">
                                <StackPane styleClass="sidebar-icon-box">
                                    <Label text="📋" style="-fx-font-size: 16px;" />
                                </StackPane>
                                <Label text="Tasks" />
                            </HBox>
                        </graphic>
                    </Button>
                </VBox>

                <Label fx:id="lblAdminSection" styleClass="section-header" text="ADMIN" />
                <VBox spacing="10.0">
                    <Button fx:id="btnAdmin" mnemonicParsing="false" onAction="#goToAdmin" prefWidth="210.0" styleClass="sidebar-item">
                        <graphic>
                            <HBox spacing="15.0" alignment="CENTER_LEFT">
                                <StackPane styleClass="sidebar-icon-box">
                                    <Label text="🛠" style="-fx-font-size: 16px;" />
                                </StackPane>
                                <Label text="Admin Panel" />
                            </HBox>
                        </graphic>
                    </Button>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />
                <Button onAction="#goBack" text="Log Out" prefHeight="45.0" prefWidth="210.0" styleClass="btn-primary" />
            </children>
        </VBox>
    </left>
    <center>
        <VBox spacing="22.0">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
            </padding>
            <children>
                <HBox styleClass="top-nav" alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <VBox>
                            <Label style="-fx-text-fill: #a0aec0; -fx-font-size: 12px;" text="Pages / Workflow" />
                            <Label styleClass="title-label" text="Tasks Management" />
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#handleAddTask" prefHeight="44.0" styleClass="btn-primary" text="＋ Add Task" />
                    </children>
                </HBox>

                <VBox VBox.vgrow="ALWAYS" styleClass="card" spacing="15">
                    <children>
                        <VBox spacing="5">
                            <Label text="Tasks Table" styleClass="card-title" />
                            <Label text="Manage and track your project assignments" styleClass="card-subtitle" />
                        </VBox>
                        <Separator />
                        <TableView fx:id="tasksTable" VBox.vgrow="ALWAYS" style="-fx-background-radius: 12; -fx-border-radius: 12;">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                                <TableColumn fx:id="colTitle" prefWidth="250.0" text="TITLE" />
                                <TableColumn fx:id="colState" prefWidth="150.0" text="STATUS" />
                                <TableColumn fx:id="colTimeLimit" prefWidth="150.0" text="DEADLINE" />
                                <TableColumn fx:id="colActions" prefWidth="180.0" text="ACTIONS" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>
