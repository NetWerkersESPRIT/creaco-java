<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="760.0" prefWidth="1280.0" styleClass="main-container" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.TSKControllers.TasksController" stylesheets="@../gui/styles.css">

    <center>
        <VBox spacing="22.0">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
            </padding>
            <children>
                <!-- Navbar -->
                <HBox styleClass="top-nav" alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <VBox>
                            <Label style="-fx-text-fill: #a0aec0; -fx-font-size: 11px;" text="Pages / Workflow / Tasks" />
                            <Label styleClass="title-label" text="Tasks Management" style="-fx-font-size: 20px;"/>
                        </VBox>
                        
                        <Region HBox.hgrow="ALWAYS" />
                        
                        <HBox alignment="CENTER" spacing="12" onMouseClicked="#onOpenProfile" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 5 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 4); -fx-cursor: hand;">
                            <children>
                                <VBox alignment="CENTER_RIGHT">
                                    <Label text="Welcome" style="-fx-text-fill: -fx-primary-pink; -fx-font-size: 10px; -fx-font-weight: bold;" />
                                    <Label fx:id="lblNavUsername" text="User" style="-fx-text-fill: -fx-text-main; -fx-font-weight: bold; -fx-font-size: 14px;" />
                                </VBox>
                                <Label fx:id="lblNavUserRole" text="USER" styleClass="badge-pink" style="-fx-font-size: 9px; -fx-padding: 2 8;"/>
                            </children>
                        </HBox>

                        <Button onAction="#logout" styleClass="btn-logout" prefHeight="40" prefWidth="40">
                            <graphic>
                                <Label text="🏃" style="-fx-text-fill: white; -fx-font-size: 16px;" />
                            </graphic>
                        </Button>
                    </children>
                </HBox>

                <!-- Tasks Card -->
                <VBox VBox.vgrow="ALWAYS" styleClass="card" spacing="15">
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <VBox spacing="5">
                                    <Label text="Tasks List" styleClass="card-title" />
                                    <Label text="Manage and track your project assignments" styleClass="card-subtitle" />
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <Button mnemonicParsing="false" onAction="#handleAddTask" prefHeight="35.0" styleClass="btn-primary" text="＋ Add Task" style="-fx-font-size: 12px;"/>
                            </children>
                        </HBox>
                        
                        <Separator />
                        
                        <!-- Header Row for the List -->
                        <HBox spacing="15.0" style="-fx-padding: 10 15; -fx-background-color: #f8fafc; -fx-background-radius: 10;">
                            <children>
                                <Label text="TASK DETAILS" style="-fx-font-weight: bold; -fx-text-fill: #64748b; -fx-font-size: 11px;" prefWidth="300"/>
                                <Region HBox.hgrow="ALWAYS" />
                                <Label text="STATUS" style="-fx-font-weight: bold; -fx-text-fill: #64748b; -fx-font-size: 11px;" prefWidth="120" alignment="CENTER"/>
                                <Label text="DEADLINE" style="-fx-font-weight: bold; -fx-text-fill: #64748b; -fx-font-size: 11px;" prefWidth="150" alignment="CENTER"/>
                                <Label text="ACTIONS" style="-fx-font-weight: bold; -fx-text-fill: #64748b; -fx-font-size: 11px;" prefWidth="200" alignment="CENTER"/>
                            </children>
                        </HBox>

                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox fx:id="tasksList" spacing="10.0" style="-fx-background-color: transparent;" />
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>
