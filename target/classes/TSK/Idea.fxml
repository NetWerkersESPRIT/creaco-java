<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="760.0" prefWidth="1280.0" styleClass="main-container" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.TSKControllers.IdeaController" stylesheets="@../gui/styles.css">

    <center>
        <VBox spacing="22.0">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
            </padding>
            <children>

                <!-- Ideas Card -->
                <VBox VBox.vgrow="ALWAYS" styleClass="card" spacing="15">
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <VBox spacing="5">
                                    <Label text="Community Ideas" styleClass="card-title" />
                                    <Label text="Browse through community submissions" styleClass="card-subtitle" />
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <HBox spacing="10">
                                    <Button mnemonicParsing="false" onAction="#handleAddIdea" prefHeight="35.0" styleClass="btn-primary" text="＋ Add Idea" style="-fx-font-size: 12px;"/>
                                    <Button fx:id="btnAdmin" mnemonicParsing="false" onAction="#goToAdmin" prefHeight="35.0" styleClass="btn-primary" style="-fx-background-color: #2d3748; -fx-font-size: 12px;" text="🛠 Admin" />
                                </HBox>
                            </children>
                        </HBox>
                        
                        <Separator />
                        
                        <!-- Header Row for the List -->
                        <HBox spacing="15.0" style="-fx-padding: 10 15; -fx-background-color: #f8fafc; -fx-background-radius: 10;">
                            <children>
                                <Label text="IDEA DETAILS" style="-fx-font-weight: bold; -fx-text-fill: #64748b; -fx-font-size: 11px;" prefWidth="300"/>
                                <Region HBox.hgrow="ALWAYS" />
                                <Label text="CATEGORY" style="-fx-font-weight: bold; -fx-text-fill: #64748b; -fx-font-size: 11px;" prefWidth="150" alignment="CENTER"/>
                                <Label text="ACTIONS" style="-fx-font-weight: bold; -fx-text-fill: #64748b; -fx-font-size: 11px;" prefWidth="150" alignment="CENTER"/>
                            </children>
                        </HBox>

                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox fx:id="ideasList" spacing="10.0" style="-fx-background-color: transparent;" />
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>
