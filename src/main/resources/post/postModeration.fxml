<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER" spacing="22.0" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.post.PostModerationController">
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
    </padding>
    <children>
        <!-- Header Section -->
        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="top-nav">
            <children>
                <VBox fx:id="headerTitleBox">
                    <children>
                        <Label style="-fx-text-fill: #a0aec0; -fx-font-size: 12px;" text="Pages / Forum / Moderation" />
                        <Label fx:id="mainTitleLabel" styleClass="title-label" text="Post Moderation" />
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Button style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 8;">
                            <graphic>
                                <Label style="-fx-font-size: 16px;" text="🔔" />
                            </graphic>
                        </Button>
                        <HBox alignment="CENTER" spacing="10.0" onMouseClicked="#onOpenProfile" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 5 15 5 15; -fx-cursor: hand;">
                            <children>
                                <VBox alignment="CENTER_RIGHT">
                                    <children>
                                        <Label style="-fx-font-size: 10px; -fx-text-fill: -fx-primary-pink; -fx-font-weight: bold;" text="Welcome" />
                                        <Label fx:id="lblUsername" style="-fx-font-size: 14px; -fx-font-weight: bold;" text="Admin User" />
                                    </children>
                                </VBox>
                                <Label fx:id="lblUserRole" styleClass="badge-pink" text="ADMIN" />
                            </children>
                        </HBox>
                        <Button onAction="#logout" styleClass="btn-logout">
                            <graphic>
                                <Label style="-fx-text-fill: white; -fx-font-size: 16px;" text="🏃" />
                            </graphic>
                        </Button>
                    </children>
                </HBox>
            </children>
        </HBox>

        <!-- Main Moderation Card -->
        <StackPane fx:id="mainContentStack" alignment="TOP_CENTER">
            <children>
                <!-- List View Container -->
                <VBox fx:id="listViewContainer" spacing="20.0" styleClass="card">
                    <padding>
                        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                            <children>
                                <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2d3748;" text="Pending Posts" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label style="-fx-text-fill: #718096; -fx-font-size: 13px;" text="Pending" />
                                <Button style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 8 15; -fx-text-fill: #4a5568; -fx-font-weight: bold;" text="🤖 Spam Filter" />
                            </children>
                        </HBox>

                        <Separator style="-fx-opacity: 0.3;" />

                        <!-- Header Row -->
                        <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-padding: 10 15 10 15;">
                            <children>
                                <Label prefWidth="300.0" style="-fx-font-weight: bold; -fx-text-fill: #cbd5e1; -fx-font-size: 11px; -fx-letter-spacing: 1;" text="TITLE" />
                                <Label prefWidth="150.0" style="-fx-font-weight: bold; -fx-text-fill: #cbd5e1; -fx-font-size: 11px; -fx-letter-spacing: 1;" text="AUTHOR" />
                                <Label prefWidth="120.0" style="-fx-font-weight: bold; -fx-text-fill: #cbd5e1; -fx-font-size: 11px; -fx-letter-spacing: 1;" text="SPAM SCORE" />
                                <Label prefWidth="200.0" style="-fx-font-weight: bold; -fx-text-fill: #cbd5e1; -fx-font-size: 11px; -fx-letter-spacing: 1;" text="CREATED AT" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label prefWidth="150.0" alignment="CENTER" style="-fx-font-weight: bold; -fx-text-fill: #cbd5e1; -fx-font-size: 11px; -fx-letter-spacing: 1;" text="ACTIONS" />
                            </children>
                        </HBox>

                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox fx:id="moderationList" spacing="0.0" />
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>

                <!-- Detail View Container -->
                <VBox fx:id="detailViewContainer" spacing="25.0" styleClass="card" visible="false">
                    <padding>
                        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <Label fx:id="detailTitleLabel" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #2d3748;" text="My Creative Portfolio 2026" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button onAction="#showList" style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-font-weight: bold; -fx-font-size: 12px; -fx-cursor: hand;" text="BACK TO LIST" />
                            </children>
                        </HBox>
                        
                        <HBox spacing="15.0" alignment="CENTER_LEFT">
                            <children>
                                <HBox spacing="5.0" alignment="CENTER_LEFT">
                                    <Label text="👤" style="-fx-text-fill: #64748b;" />
                                    <Label fx:id="detailAuthorLabel" style="-fx-text-fill: #64748b; -fx-font-weight: bold; -fx-font-size: 12px;" text="RANIM" />
                                </HBox>
                                <HBox spacing="5.0" alignment="CENTER_LEFT">
                                    <Label text="📅" style="-fx-text-fill: #64748b;" />
                                    <Label fx:id="detailDateLabel" style="-fx-text-fill: #64748b; -fx-font-weight: bold; -fx-font-size: 12px;" text="APRIL 22, 2026, 1:13 PM" />
                                </HBox>
                                <Label fx:id="detailStatusLabel" style="-fx-text-fill: #64748b; -fx-font-weight: bold; -fx-font-size: 12px;" text="PENDING" />
                                <Label fx:id="pinRequestLabel" text="📌 Pin requested" style="-fx-text-fill: #ce2d7c; -fx-font-weight: bold; -fx-font-size: 12px;" visible="false" managed="false" />
                            </children>
                        </HBox>

                        <VBox style="-fx-background-color: #f8fafc; -fx-background-radius: 15; -fx-padding: 30; -fx-border-color: #f1f5f9; -fx-border-radius: 15;" VBox.vgrow="ALWAYS">
                            <children>
                                <Label fx:id="detailContentLabel" text="heyyyyyyyyyy" wrapText="true" style="-fx-font-size: 16px; -fx-text-fill: #4a5568; -fx-line-spacing: 5;" />
                            </children>
                        </VBox>

                        <HBox alignment="CENTER_RIGHT" spacing="20.0">
                            <children>
                                <Button onAction="#handleRefuse" style="-fx-background-color: #ff3b3b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 14 30; -fx-cursor: hand;" text="ⓧ REFUSE POST" />
                                <Button onAction="#handleApprove" style="-fx-background-color: #4ade80; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 14 30; -fx-cursor: hand;" text="✔️ APPROVE POST" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </children>
</VBox>
