<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>

<VBox spacing="22.0" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.post.DisplayPostController">
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
    </padding>
    <children>
        <Label fx:id="statusLabel" style="-fx-text-fill: -fx-primary-pink; -fx-font-size: 13px; -fx-font-weight: bold;" text="Ready" />
        <!-- New Action Row: Recent Discussions + Search + Add Post -->
        <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="card" style="-fx-padding: 15 25;">
            <children>
                <Button fx:id="btnBack" onAction="#goWelcome" style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;" text="←" />
                <Label text="Recent Discussions" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2d3748;" />
                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="search-bar" prefWidth="350.0" maxWidth="400.0">
                    <children>
                        <Label text="🔍" style="-fx-font-size: 14px; -fx-text-fill: #a0aec0;" />
                        <TextField fx:id="searchField" onKeyReleased="#onSearch" promptText="Search discussions..." 
                                   style="-fx-background-color: transparent; -fx-padding: 0;" HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" onAction="#goAddPost" styleClass="btn-primary" prefHeight="45.0" prefWidth="210.0" text="+ CREATE NEW POST" />
            </children>
        </HBox>

        <!-- Posts List -->
        <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" hbarPolicy="NEVER" pannable="true" style="-fx-background: transparent; -fx-background-color: transparent;">
            <content>
                <VBox fx:id="postsContainer" spacing="20.0" style="-fx-background-color: transparent;">
                    <padding>
                        <Insets bottom="20.0" left="5.0" right="5.0" top="10.0" />
                    </padding>
                    <!-- Empty state will be injected here if no posts -->
                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>
