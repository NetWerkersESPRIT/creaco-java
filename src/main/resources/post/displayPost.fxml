<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>

<VBox spacing="22.0" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.post.DisplayPostController">
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
    </padding>
    <children>
        <!-- Header Section (Dashboard Style) - UNCHANGED as per request -->
        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="top-nav">
            <children>
                <VBox>
                    <children>
                        <Label style="-fx-text-fill: #a0aec0; -fx-font-size: 12px;" text="Pages / Forum" />
                        <Label styleClass="title-label" text="Forum" />
                        <Label fx:id="statusLabel" style="-fx-text-fill: -fx-primary-pink; -fx-font-size: 11px;" text="Ready" />
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Button style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 8;">
                            <graphic>
                                <Label style="-fx-font-size: 16px;" text="🔔" />
                            </graphic>
                        </Button>
                        <HBox alignment="CENTER" spacing="10.0" onMouseClicked="#onOpenProfile" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 5 15 5 15; -fx-cursor: hand;">
                            <children>
                                <VBox alignment="CENTER_RIGHT">
                                    <children>
                                        <Label style="-fx-font-size: 10px; -fx-text-fill: -fx-primary-pink; -fx-font-weight: bold;" text="Welcome" />
                                        <Label fx:id="lblUsername" style="-fx-font-size: 14px; -fx-font-weight: bold;" text="Admin User" />
                                    </children>
                                </VBox>
                                <Label fx:id="lblUserRole" styleClass="badge-pink" text="ADMIN" />
                            </children>
                        </HBox>
                        <Button onAction="#logout" styleClass="btn-logout">
                            <graphic>
                                <Label style="-fx-text-fill: white; -fx-font-size: 16px;" text="🏃" />
                            </graphic>
                        </Button>
                    </children>
                </HBox>
            </children>
        </HBox>

        <!-- New Action Row: Recent Discussions + Search + Add Post -->
        <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="card" style="-fx-padding: 15 25;">
            <children>
                <Label text="Recent Discussions" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2d3748;" />
                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="search-bar" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                    <children>
                        <Label text="🔍" style="-fx-font-size: 14px; -fx-text-fill: #a0aec0;" />
                        <TextField fx:id="searchField" onKeyReleased="#onSearch" promptText="Search discussions..." 
                                   style="-fx-background-color: transparent; -fx-padding: 0;" HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>
                <Button mnemonicParsing="false" onAction="#goAddPost" styleClass="btn-primary" prefHeight="45.0" prefWidth="180.0" text="+ CREATE NEW POST" />
            </children>
        </HBox>

        <!-- Posts List -->
        <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" hbarPolicy="NEVER" pannable="true" style="-fx-background: transparent; -fx-background-color: transparent;">
            <content>
                <VBox fx:id="postsContainer" spacing="20.0" style="-fx-background-color: transparent;">
                    <padding>
                        <Insets bottom="20.0" left="5.0" right="5.0" top="10.0" />
                    </padding>
                    <!-- Empty state will be injected here if no posts -->
                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>
