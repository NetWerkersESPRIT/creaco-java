<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="22.0" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.post.DisplayPostController">
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
    </padding>
    <children>
        <HBox alignment="CENTER_LEFT" spacing="12.0">
            <children>
                <VBox spacing="6.0">
                    <children>
                        <Label style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #243b63;" text="Forum Posts" />
                        <Label style="-fx-font-size: 14px; -fx-text-fill: #64748b;" text="Review discussions and manage your posts." />
                        <Label fx:id="statusLabel" style="-fx-font-size: 13px; -fx-text-fill: #355388;" text="Loading posts..." />
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" onAction="#goAddPost" style="-fx-background-color: #355388; -fx-text-fill: white; -fx-background-radius: 12; -fx-font-weight: bold; -fx-padding: 10 18 10 18;" text="+ Add Post" />
            </children>
        </HBox>

        <!-- Search Bar -->
        <HBox alignment="CENTER_LEFT" spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #dbe4f0; -fx-border-radius: 12; -fx-padding: 8 12 8 12;">
            <children>
                <TextField fx:id="searchField" onKeyReleased="#onSearch" promptText="Search posts by title..." style="-fx-background-color: transparent; -fx-prompt-text-fill: #94a3b8; -fx-font-size: 14px;" HBox.hgrow="ALWAYS" />
            </children>
        </HBox>

        <!-- Posts List -->
        <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" hbarPolicy="NEVER" pannable="true" style="-fx-background: transparent; -fx-background-color: transparent;">
            <content>
                <VBox fx:id="postsContainer" spacing="16.0" style="-fx-background-color: transparent;">
                    <padding>
                        <Insets bottom="12.0" left="0.0" right="0.0" top="0.0" />
                    </padding>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>
