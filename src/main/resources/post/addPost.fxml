<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="700.0" prefWidth="800.0" spacing="20.0" style="-fx-background-color: #ecf0f1; -fx-padding: 30;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.post.AddPostController">
    <children>
        <Label text="Add New Post" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>
        
        <VBox spacing="5.0">
            <Label text="Title:" textFill="#34495e">
                <font>
                    <Font name="System Bold" size="14.0" />
                </font>
            </Label>
            <TextField fx:id="titleField" promptText="Enter post title..." style="-fx-font-size: 14px; -fx-padding: 10;" />
        </VBox>
        
        <VBox spacing="5.0">
            <Label text="Content:" textFill="#34495e">
                <font>
                    <Font name="System Bold" size="14.0" />
                </font>
            </Label>
            <TextArea fx:id="contentArea" prefHeight="200.0" promptText="Enter post content..." style="-fx-font-size: 14px; -fx-padding: 10;" wrapText="true" />
        </VBox>
        
        <Button mnemonicParsing="false" onAction="#savePost" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 10 20;" text="Save Post" />
        <Button mnemonicParsing="false" onAction="#goBack" style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 10 20;" text="Back to Posts" />
    </children>
</VBox>
