<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="400.0" prefHeight="500.0" spacing="0.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5);" 
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="gui.notification.NotificationListController">
    <children>
        <HBox alignment="CENTER_LEFT" style="-fx-padding: 15 20; -fx-background-color: #f8fafc; -fx-background-radius: 15 15 0 0;">
            <children>
                <Label text="Notifications" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="Mark all as read" onAction="#onMarkAllRead" 
                        style="-fx-background-color: transparent; -fx-text-fill: #ce2d7c; -fx-font-size: 12px; -fx-cursor: hand;" />
            </children>
        </HBox>
        
        <ScrollPane fitToWidth="true" style="-fx-background-color: white; -fx-background: white;" VBox.vgrow="ALWAYS" hbarPolicy="NEVER">
            <content>
                <VBox fx:id="notificationContainer" spacing="1.0" style="-fx-background-color: #f1f5f9;">
                    <padding>
                        <Insets bottom="10.0" />
                    </padding>
                </VBox>
            </content>
        </ScrollPane>
        
        <HBox alignment="CENTER" style="-fx-padding: 10; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0;">
            <children>
                <Button text="Close" onAction="#onClose" 
                        style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-background-radius: 8; -fx-padding: 5 20;" />
            </children>
        </HBox>
    </children>
</VBox>
