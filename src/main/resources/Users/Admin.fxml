<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="22.0" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.UsersControllers.AdminController" stylesheets="@../gui/styles.css">
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
    </padding>
    <children>
        <!-- Premium Navbar -->
        <HBox styleClass="top-nav" alignment="CENTER_LEFT" spacing="20.0">
            <children>
                <VBox>
                    <Label style="-fx-text-fill: #a0aec0; -fx-font-size: 11px;" text="Pages / Admin / Users" />
                    <Label styleClass="title-label" text="Admin Panel" style="-fx-font-size: 20px;"/>
                </VBox>
                
                <Region HBox.hgrow="ALWAYS" />
                

                <HBox alignment="CENTER" spacing="12" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 5 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 4);">
                    <children>
                        <VBox alignment="CENTER_RIGHT">
                            <Label text="Welcome" style="-fx-text-fill: -fx-primary-pink; -fx-font-size: 10px; -fx-font-weight: bold;" />
                            <Label fx:id="lblNavUsername" text="Admin User" style="-fx-text-fill: -fx-text-main; -fx-font-weight: bold; -fx-font-size: 14px;" />
                        </VBox>
                        <Label fx:id="lblNavUserRole" text="ADMIN" styleClass="badge-pink" style="-fx-font-size: 9px; -fx-padding: 2 8;"/>
                    </children>
                </HBox>

                <Button onAction="#logout" styleClass="btn-logout" prefHeight="40" prefWidth="40">
                    <graphic>
                        <Label text="🏃" style="-fx-text-fill: white; -fx-font-size: 16px;" />
                    </graphic>
                </Button>
            </children>
        </HBox>

        <!-- Users Table Card -->
        <VBox VBox.vgrow="ALWAYS" styleClass="card" spacing="15">
            <children>
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <VBox spacing="5">
                            <Label text="Users table" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2d3748;" />
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#handleAddUser" styleClass="btn-primary" text="+ Add New User" prefHeight="35.0" prefWidth="150.0" style="-fx-font-size: 12px;" />
                    </children>
                </HBox>
                
                <Separator style="-fx-opacity: 0.3;" />

                <!-- Table Header -->
                <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-padding: 10 15 10 15;">
                    <children>
                        <Label prefWidth="300.0" style="-fx-font-weight: bold; -fx-text-fill: #cbd5e1; -fx-font-size: 11px; -fx-letter-spacing: 1;" text="USER INFO" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label prefWidth="180.0" alignment="CENTER" style="-fx-font-weight: bold; -fx-text-fill: #cbd5e1; -fx-font-size: 11px; -fx-letter-spacing: 1;" text="ROLE" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label prefWidth="180.0" alignment="CENTER" style="-fx-font-weight: bold; -fx-text-fill: #cbd5e1; -fx-font-size: 11px; -fx-letter-spacing: 1;" text="PHONE NUMBER" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label prefWidth="200.0" alignment="CENTER" style="-fx-font-weight: bold; -fx-text-fill: #cbd5e1; -fx-font-size: 11px; -fx-letter-spacing: 1;" text="ACTIONS" />
                    </children>
                </HBox>

                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox fx:id="usersList" spacing="0.0" style="-fx-background-color: white;" />
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </children>
</VBox>