<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.Text?>
<?import javafx.geometry.Insets?>

<StackPane
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="gui.UsersControllers.SignInController"
    stylesheets="@../gui/styles.css"
    prefWidth="1000" prefHeight="700"
    styleClass="main-container">

    <HBox alignment="CENTER" spacing="0">
        <!-- LEFT HERO PANEL (Gradient background) -->
        <VBox prefWidth="400" alignment="CENTER" spacing="25" 
              style="-fx-background-color: linear-gradient(to bottom right, #ce2d7c, #6c2db1); -fx-background-radius: 0 50 50 0;">
            <padding><Insets bottom="40" left="40" right="40" top="40"/></padding>
            
            <StackPane prefWidth="80" prefHeight="80" 
                       style="-fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 20;">
                <Label text="C" style="-fx-text-fill: white; -fx-font-size: 36px; -fx-font-weight: bold;"/>
            </StackPane>

            <VBox alignment="CENTER" spacing="10">
                <Label text="Welcome back!" style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                <Label text="The most modern way to manage your creative projects and tasks." 
                       wrapText="true" textAlignment="CENTER"
                       style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 14px;"/>
            </VBox>
            
            <VBox VBox.vgrow="ALWAYS" />
            <Label text="© 2025 Creaco - Soft UI Dashboard" style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 12px;"/>
        </VBox>

        <!-- RIGHT FORM PANEL -->
        <VBox HBox.hgrow="ALWAYS" alignment="CENTER" style="-fx-background-color: -fx-background;">
            <VBox maxWidth="380" spacing="20" styleClass="card">
                <VBox spacing="5">
                    <Label text="Sign In" styleClass="title-label" />
                    <Label text="Enter your credentials to access your account" styleClass="subtitle-label" />
                </VBox>

                <Separator/>

                <VBox spacing="8">
                    <Label text="EMAIL" styleClass="section-header" style="-fx-padding: 0;"/>
                    <TextField fx:id="txtEmail" promptText="you@example.com" styleClass="search-bar" />
                </VBox>

                <VBox spacing="8">
                    <Label text="PASSWORD" styleClass="section-header" style="-fx-padding: 0;"/>
                    <PasswordField fx:id="txtPassword" promptText="••••••••" styleClass="search-bar" />
                </VBox>

                <Button text="Sign In" onAction="#handleLogin" maxWidth="Infinity" prefHeight="45" styleClass="btn-primary" />
                
                <Label fx:id="lblMessage" style="-fx-text-fill: #e53e3e; -fx-font-size: 13px;" />

                <HBox alignment="CENTER" spacing="10">
                    <Separator HBox.hgrow="ALWAYS"/>
                    <Label text="or" styleClass="subtitle-label"/>
                    <Separator HBox.hgrow="ALWAYS"/>
                </HBox>

                <Button text="Create an Account" onAction="#goToRegister" maxWidth="Infinity" prefHeight="45" 
                        style="-fx-background-color: transparent; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-text-fill: -fx-text-main; -fx-font-weight: bold;" />
            </VBox>
        </VBox>
    </HBox>

</StackPane>
