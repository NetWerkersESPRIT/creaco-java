<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<VBox spacing="20.0" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.UsersControllers.EditUserController" stylesheets="@../gui/styles.css">
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
    </padding>
    <children>

        <!-- Main Form Container -->
        <StackPane VBox.vgrow="ALWAYS">
            <children>
                <!-- Background Wave/Gradient Container -->
                <VBox prefHeight="300" maxHeight="300" style="-fx-background-color: linear-gradient(to right, #ce2d7c, #6c2db1, #3b82f6); -fx-background-radius: 20;" StackPane.alignment="TOP_CENTER" />
                
                <!-- White Form Card -->
                <VBox spacing="30.0" styleClass="card" maxWidth="950" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 40;">
                    <StackPane.margin>
                        <Insets top="80.0" />
                    </StackPane.margin>
                    <children>
                        <Label fx:id="lblTitle" text="Account Details: user_name" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2d3748;" />
                        
                        <GridPane hgap="30.0" vgap="20.0">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50" />
                                <ColumnConstraints percentWidth="50" />
                            </columnConstraints>
                            <children>
                                <VBox spacing="8.0" GridPane.columnIndex="0">
                                    <children>
                                        <Label text="Username" style="-fx-font-weight: bold; -fx-text-fill: #4a5568; -fx-font-size: 12px;" />
                                        <TextField fx:id="txtUsername" promptText="Enter username" styleClass="search-bar" prefHeight="45" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0" GridPane.columnIndex="1">
                                    <children>
                                        <Label text="Email Address" style="-fx-font-weight: bold; -fx-text-fill: #4a5568; -fx-font-size: 12px;" />
                                        <TextField fx:id="txtEmail" promptText="user@example.com" styleClass="search-bar" prefHeight="45" />
                                    </children>
                                </VBox>
                            </children>
                        </GridPane>

                        <Separator style="-fx-opacity: 0.3;" />

                        <VBox spacing="20.0">
                            <children>
                                <Label text="Security &amp; Contact" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2d3748;" />
                                
                                <VBox spacing="8.0">
                                    <children>
                                        <Label text="New Password (Leave blank to keep current)" style="-fx-font-weight: bold; -fx-text-fill: #4a5568; -fx-font-size: 12px;" />
                                        <PasswordField fx:id="txtPassword" promptText="Leave blank to keep current password" styleClass="search-bar" prefHeight="45" />
                                    </children>
                                </VBox>

                                <VBox spacing="8.0">
                                    <children>
                                        <Label text="Phone Number" style="-fx-font-weight: bold; -fx-text-fill: #4a5568; -fx-font-size: 12px;" />
                                        <TextField fx:id="txtNumtel" promptText="Phone Number" styleClass="search-bar" prefHeight="45" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <VBox spacing="15.0" style="-fx-padding: 20 0 0 0;">
                            <children>
                                <Button onAction="#updateUser" text="UPDATE USER ACCOUNT" prefHeight="50" maxWidth="Infinity" styleClass="btn-primary" />
                                <Button onAction="#goBack" text="RETURN TO CONNECTED USERS" prefHeight="50" maxWidth="Infinity" style="-fx-background-color: white; -fx-border-color: -fx-primary-pink; -fx-border-radius: 12; -fx-text-fill: -fx-primary-pink; -fx-font-weight: bold; -fx-cursor: hand;" />
                            </children>
                        </VBox>
                        
                        <Label fx:id="lblMessage" style="-fx-font-weight: bold;" />
                    </children>
                </VBox>
            </children>
        </StackPane>
    </children>
</VBox>