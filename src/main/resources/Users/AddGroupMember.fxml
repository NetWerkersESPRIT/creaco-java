<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="22.0" style="-fx-background-color: transparent;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.UsersControllers.AddGroupMemberController">
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
    </padding>
    <children>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
            <content>
                <StackPane>
                    <children>
                        <VBox maxWidth="750.0" spacing="25.0" styleClass="card" alignment="TOP_CENTER">
                            <padding>
                                <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
                            </padding>
                            <children>
                                <!-- Title -->
                                <VBox spacing="4.0" alignment="TOP_LEFT" maxWidth="Infinity">
                                    <children>
                                        <Label text="Manage Team Members" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2d3748;" />
                                        <Label text="Grow your content creation team by adding or inviting collaborators." style="-fx-font-size: 13px; -fx-text-fill: #718096;" />
                                    </children>
                                </VBox>

                                <Separator style="-fx-opacity: 0.4;" />

                                <javafx.scene.control.TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" styleClass="floating-tabs">
                                    <tabs>
                                        <!-- CREATE NEW USER TAB -->
                                        <javafx.scene.control.Tab text="Create New Member">
                                            <content>
                                                <VBox spacing="18.0" style="-fx-padding: 20 0 0 0;">
                                                    <children>
                                                        <VBox spacing="6.0">
                                                            <children>
                                                                <Label text="USERNAME" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #a0aec0; -fx-letter-spacing: 1;" />
                                                                <TextField fx:id="txtUsername" promptText="Enter username..."
                                                                           style="-fx-background-color: white; -fx-border-color: #dbe4f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12; -fx-font-size: 14px;" />
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="6.0">
                                                            <children>
                                                                <Label text="EMAIL ADDRESS" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #a0aec0; -fx-letter-spacing: 1;" />
                                                                <TextField fx:id="txtEmail" promptText="Enter email address..."
                                                                           style="-fx-background-color: white; -fx-border-color: #dbe4f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12; -fx-font-size: 14px;" />
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="6.0">
                                                            <children>
                                                                <Label text="PASSWORD" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #a0aec0; -fx-letter-spacing: 1;" />
                                                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                                                    <children>
                                                                        <StackPane HBox.hgrow="ALWAYS">
                                                                            <children>
                                                                                <TextField fx:id="txtPasswordVisible" managed="false" visible="false" promptText="Enter password..."
                                                                                           style="-fx-background-color: white; -fx-border-color: #dbe4f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12; -fx-font-size: 14px;" />
                                                                                <PasswordField fx:id="txtPassword" promptText="Enter password..."
                                                                                               style="-fx-background-color: white; -fx-border-color: #dbe4f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12; -fx-font-size: 14px;" />
                                                                            </children>
                                                                        </StackPane>
                                                                        <Button fx:id="btnTogglePassword" onAction="#togglePassword" text="👁"
                                                                                style="-fx-background-color: #f3f4f6; -fx-background-radius: 10; -fx-min-width: 45; -fx-min-height: 45; -fx-cursor: hand;" />
                                                                    </children>
                                                                </HBox>
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="6.0">
                                                            <children>
                                                                <Label text="PHONE NUMBER" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #a0aec0; -fx-letter-spacing: 1;" />
                                                                <TextField fx:id="txtNumtel" promptText="Enter phone number (8 digits)..."
                                                                           style="-fx-background-color: white; -fx-border-color: #dbe4f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12; -fx-font-size: 14px;" />
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="6.0">
                                                            <children>
                                                                <Label text="TEAM ROLE" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #a0aec0; -fx-letter-spacing: 1;" />
                                                                <ComboBox fx:id="comboRole" maxWidth="Infinity"
                                                                          style="-fx-background-color: white; -fx-border-color: #dbe4f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 8; -fx-font-size: 14px;" />
                                                            </children>
                                                        </VBox>
                                                        <Button text="👤 Create &amp; Add Member" onAction="#saveMember"
                                                                maxWidth="Infinity" styleClass="btn-primary" prefHeight="48" />
                                                    </children>
                                                </VBox>
                                            </content>
                                        </javafx.scene.control.Tab>

                                        <!-- INVITE EXISTING USER TAB -->
                                        <javafx.scene.control.Tab text="Invite Existing User">
                                            <content>
                                                <VBox spacing="25.0" style="-fx-padding: 25 0 0 0;">
                                                    <children>
                                                        <VBox spacing="8.0">
                                                            <children>
                                                                <Label text="SEARCH USER" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #a0aec0; -fx-letter-spacing: 1;" />
                                                                <ComboBox fx:id="comboInviteUser" maxWidth="Infinity" promptText="Select a user to invite..."
                                                                          style="-fx-background-color: white; -fx-border-color: #dbe4f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10; -fx-font-size: 14px;" />
                                                                <Label text="Only showing users with ROLE_MEMBER or ROLE_MANAGER." style="-fx-font-size: 11px; -fx-text-fill: #a0aec0;" />
                                                            </children>
                                                        </VBox>

                                                        <VBox spacing="8.0" style="-fx-background-color: #f7fafc; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #edf2f7; -fx-border-radius: 10;">
                                                            <children>
                                                                <Label text="Invitation Message" style="-fx-font-weight: bold; -fx-text-fill: #4a5568;" />
                                                                <Label text="An invitation will be sent to the user. They must accept it before being added to your team." 
                                                                       wrapText="true" style="-fx-font-size: 13px; -fx-text-fill: #718096;" />
                                                            </children>
                                                        </VBox>

                                                        <Button text="✉  Send Invitation" onAction="#handleSendInvitation"
                                                                maxWidth="Infinity" styleClass="btn-primary" prefHeight="48" />
                                                    </children>
                                                </VBox>
                                            </content>
                                        </javafx.scene.control.Tab>
                                    </tabs>
                                </javafx.scene.control.TabPane>

                                <Label fx:id="lblMessage" text="" wrapText="true" style="-fx-font-size: 13px; -fx-font-weight: bold;" />

                                <Separator style="-fx-opacity: 0.4;" />

                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Button text="← Back to Management" onAction="#goBack"
                                                style="-fx-background-color: transparent; -fx-text-fill: #718096; -fx-font-weight: bold; -fx-cursor: hand;" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </StackPane>
            </content>
        </ScrollPane>
    </children>
</VBox>
