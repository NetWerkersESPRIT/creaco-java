<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="22.0" style="-fx-background-color: transparent;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.UsersControllers.AddGroupMemberController">
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
    </padding>
    <children>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
            <content>
                <StackPane>
                    <children>
                        <VBox maxWidth="750.0" spacing="25.0" styleClass="card" alignment="TOP_CENTER">
                            <padding>
                                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
                            </padding>
                            <children>
                                <!-- Title -->
                                <VBox spacing="4.0" alignment="TOP_LEFT" maxWidth="Infinity">
                                    <children>
                                        <Label text="Add New Team Member" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2d3748;" />
                                        <Label text="Create a new user and assign them to your team group." style="-fx-font-size: 13px; -fx-text-fill: #718096;" />
                                    </children>
                                </VBox>

                                <Separator style="-fx-opacity: 0.4;" />

                                <!-- Form Fields -->
                                <VBox spacing="18.0">
                                    <children>
                                        <!-- Username -->
                                        <VBox spacing="6.0">
                                            <children>
                                                <Label text="USERNAME" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #a0aec0; -fx-letter-spacing: 1;" />
                                                <TextField fx:id="txtUsername" promptText="Enter username..."
                                                           style="-fx-background-color: white; -fx-border-color: #dbe4f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12; -fx-font-size: 14px;" />
                                            </children>
                                        </VBox>

                                        <!-- Email -->
                                        <VBox spacing="6.0">
                                            <children>
                                                <Label text="EMAIL ADDRESS" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #a0aec0; -fx-letter-spacing: 1;" />
                                                <TextField fx:id="txtEmail" promptText="Enter email address..."
                                                           style="-fx-background-color: white; -fx-border-color: #dbe4f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12; -fx-font-size: 14px;" />
                                            </children>
                                        </VBox>

                                        <!-- Password -->
                                        <VBox spacing="6.0">
                                            <children>
                                                <Label text="PASSWORD" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #a0aec0; -fx-letter-spacing: 1;" />
                                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                                    <children>
                                                        <StackPane HBox.hgrow="ALWAYS">
                                                            <children>
                                                                <TextField fx:id="txtPasswordVisible" managed="false" visible="false" promptText="Enter password..."
                                                                           style="-fx-background-color: white; -fx-border-color: #dbe4f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12; -fx-font-size: 14px;" />
                                                                <PasswordField fx:id="txtPassword" promptText="Enter password..."
                                                                               style="-fx-background-color: white; -fx-border-color: #dbe4f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12; -fx-font-size: 14px;" />
                                                            </children>
                                                        </StackPane>
                                                        <Button fx:id="btnTogglePassword" onAction="#togglePassword" text="👁"
                                                                style="-fx-background-color: #f3f4f6; -fx-background-radius: 10; -fx-min-width: 45; -fx-min-height: 45; -fx-cursor: hand;" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>

                                        <!-- Phone -->
                                        <VBox spacing="6.0">
                                            <children>
                                                <Label text="PHONE NUMBER" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #a0aec0; -fx-letter-spacing: 1;" />
                                                <TextField fx:id="txtNumtel" promptText="Enter phone number (8 digits)..."
                                                           style="-fx-background-color: white; -fx-border-color: #dbe4f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12; -fx-font-size: 14px;" />
                                            </children>
                                        </VBox>

                                        <!-- Role -->
                                        <VBox spacing="6.0">
                                            <children>
                                                <Label text="TEAM ROLE" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #a0aec0; -fx-letter-spacing: 1;" />
                                                <ComboBox fx:id="comboRole" maxWidth="Infinity"
                                                          style="-fx-background-color: white; -fx-border-color: #dbe4f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 8; -fx-font-size: 14px;" />
                                            </children>
                                        </VBox>

                                        <!-- Feedback label -->
                                        <Label fx:id="lblMessage" text="" wrapText="true"
                                               style="-fx-font-size: 13px; -fx-font-weight: bold;" />
                                    </children>
                                </VBox>

                                <Separator style="-fx-opacity: 0.4;" />

                                <!-- Action Buttons -->
                                <HBox alignment="CENTER_RIGHT" spacing="15.0">
                                    <children>
                                        <Button text="← Cancel" onAction="#goBack"
                                                style="-fx-background-color: white; -fx-border-color: #dbe4f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-text-fill: #4a5568; -fx-font-weight: bold; -fx-padding: 12 24; -fx-cursor: hand;"
                                                prefHeight="48" />
                                        <Button text="👤 Add Member" onAction="#saveMember"
                                                styleClass="btn-primary"
                                                prefWidth="220" prefHeight="48" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </StackPane>
            </content>
        </ScrollPane>
    </children>
</VBox>
