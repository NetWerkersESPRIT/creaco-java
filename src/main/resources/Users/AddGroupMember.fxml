<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="22.0" style="-fx-background-color: transparent;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.UsersControllers.AddGroupMemberController">
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
    </padding>
    <children>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
            <content>
                <StackPane>
                    <children>
                        <VBox maxWidth="750.0" spacing="25.0" styleClass="card" alignment="TOP_CENTER">
                            <padding>
                                <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
                            </padding>
                            <children>
                                <!-- Title -->
                                <VBox spacing="4.0" alignment="TOP_LEFT" maxWidth="Infinity">
                                    <children>
                                        <Label text="Manage Team Members" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2d3748;" />
                                        <Label text="Grow your content creation team by adding or inviting collaborators." style="-fx-font-size: 13px; -fx-text-fill: #718096;" />
                                    </children>
                                </VBox>

                                <Separator style="-fx-opacity: 0.4;" />

                                <javafx.scene.control.TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" styleClass="floating-tabs" style="-fx-tab-min-width: 180;">
                                    <tabs>
                                        <!-- CREATE NEW MEMBER TAB -->
                                        <javafx.scene.control.Tab text="👤 Create New Member">
                                            <content>
                                                <VBox spacing="20.0" style="-fx-padding: 25 0 0 0;">
                                                    <children>
                                                        <VBox spacing="8.0">
                                                            <children>
                                                                <Label text="USERNAME" styleClass="form-label" style="-fx-font-size: 11px; -fx-text-fill: #94a3b8; -fx-letter-spacing: 0.5;" />
                                                                <TextField fx:id="txtUsername" promptText="Enter username..." />
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="8.0">
                                                            <children>
                                                                <Label text="EMAIL ADDRESS" styleClass="form-label" style="-fx-font-size: 11px; -fx-text-fill: #94a3b8; -fx-letter-spacing: 0.5;" />
                                                                <TextField fx:id="txtEmail" promptText="Enter email address..." />
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="8.0">
                                                            <children>
                                                                <Label text="PASSWORD" styleClass="form-label" style="-fx-font-size: 11px; -fx-text-fill: #94a3b8; -fx-letter-spacing: 0.5;" />
                                                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                                                    <children>
                                                                        <StackPane HBox.hgrow="ALWAYS">
                                                                            <children>
                                                                                <TextField fx:id="txtPasswordVisible" managed="false" visible="false" promptText="Enter password..." />
                                                                                <PasswordField fx:id="txtPassword" promptText="Enter password..." />
                                                                            </children>
                                                                        </StackPane>
                                                                        <Button fx:id="btnTogglePassword" onAction="#togglePassword" text="👁"
                                                                                style="-fx-background-color: #f1f5f9; -fx-background-radius: 12; -fx-min-width: 48; -fx-min-height: 48; -fx-cursor: hand;" />
                                                                    </children>
                                                                </HBox>
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="8.0">
                                                            <children>
                                                                <Label text="PHONE NUMBER" styleClass="form-label" style="-fx-font-size: 11px; -fx-text-fill: #94a3b8; -fx-letter-spacing: 0.5;" />
                                                                <TextField fx:id="txtNumtel" promptText="Enter phone number (8 digits)..." />
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="8.0">
                                                            <children>
                                                                <Label text="TEAM ROLE" styleClass="form-label" style="-fx-font-size: 11px; -fx-text-fill: #94a3b8; -fx-letter-spacing: 0.5;" />
                                                                <ComboBox fx:id="comboRole" maxWidth="Infinity" promptText="Select Role" />
                                                            </children>
                                                        </VBox>
                                                        <Button text="👤 Create &amp; Add Member" onAction="#saveMember"
                                                                maxWidth="Infinity" styleClass="btn-primary" prefHeight="50" />
                                                    </children>
                                                </VBox>
                                            </content>
                                        </javafx.scene.control.Tab>

                                        <!-- INVITE EXISTING USER TAB -->
                                        <javafx.scene.control.Tab text="✉  Invite Existing User">
                                            <content>
                                                <VBox spacing="25.0" style="-fx-padding: 25 0 0 0;">
                                                    <children>
                                                        <VBox spacing="8.0">
                                                            <children>
                                                                <Label text="SEARCH USER" styleClass="form-label" style="-fx-font-size: 11px; -fx-text-fill: #94a3b8; -fx-letter-spacing: 0.5;" />
                                                                <ComboBox fx:id="comboInviteUser" maxWidth="Infinity" promptText="Select a user to invite..." />
                                                                <Label text="Only showing users with ROLE_MEMBER or ROLE_MANAGER." style="-fx-font-size: 12px; -fx-text-fill: #94a3b8; -fx-font-style: italic;" />
                                                            </children>
                                                        </VBox>

                                                        <VBox spacing="10.0" style="-fx-background-color: #f8fafc; -fx-padding: 20; -fx-background-radius: 15; -fx-border-color: #e2e8f0; -fx-border-radius: 15;">
                                                            <children>
                                                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                                                    <children>
                                                                        <Label text="✉" style="-fx-font-size: 18px; -fx-text-fill: -fx-primary-pink;" />
                                                                        <Label text="Invitation Message" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 15px;" />
                                                                    </children>
                                                                </HBox>
                                                                <Label text="An invitation will be sent to the user. They must accept it before being added to your team." 
                                                                       wrapText="true" style="-fx-font-size: 13px; -fx-text-fill: #64748b; -fx-line-spacing: 1.4;" />
                                                            </children>
                                                        </VBox>

                                                        <Button text="✉  Send Invitation" onAction="#handleSendInvitation"
                                                                maxWidth="Infinity" styleClass="btn-primary" prefHeight="50" />
                                                    </children>
                                                </VBox>
                                            </content>
                                        </javafx.scene.control.Tab>
                                    </tabs>
                                </javafx.scene.control.TabPane>


                                <Label fx:id="lblMessage" text="" wrapText="true" style="-fx-font-size: 13px; -fx-font-weight: bold;" />

                                <Separator style="-fx-opacity: 0.4;" />

                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Button text="← Back to Management" onAction="#goBack"
                                                style="-fx-background-color: transparent; -fx-text-fill: #718096; -fx-font-weight: bold; -fx-cursor: hand;" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </StackPane>
            </content>
        </ScrollPane>
    </children>
</VBox>
