<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="22.0" style="-fx-background-color: transparent;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.UsersControllers.EditProfileController">
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
    </padding>
    <children>

        <!-- Edit Card -->
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
            <content>
                <StackPane>
            <children>
                <VBox maxWidth="750.0" spacing="25.0" styleClass="card" alignment="TOP_CENTER">
                    <padding>
                        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
                    </padding>
                    <children>
                        <!-- Title -->
                        <VBox spacing="4.0">
                            <children>
                                <Label text="Update Your Information" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2d3748;" />
                                <Label text="Changes will be saved immediately to your account." style="-fx-font-size: 13px; -fx-text-fill: #718096;" />
                            </children>
                        </VBox>

                        <!-- AI Avatar Section -->
                        <VBox spacing="15.0" alignment="CENTER">
                            <children>
                                <StackPane style="-fx-background-color: #f3f4f6; -fx-background-radius: 50; -fx-padding: 2;">
                                    <children>
                                        <javafx.scene.image.ImageView fx:id="imgAvatar" fitHeight="120.0" fitWidth="120.0" pickOnBounds="true" preserveRatio="true">
                                            <clip>
                                                <javafx.scene.shape.Circle centerX="60" centerY="60" radius="60" />
                                            </clip>
                                        </javafx.scene.image.ImageView>
                                    </children>
                                </StackPane>
                                
                                <HBox spacing="10" alignment="CENTER">
                                    <children>
                                        <TextField fx:id="txtAiPrompt" promptText="Enter a prompt (e.g. 'coding wizard')" 
                                                   style="-fx-background-color: #f3f4f6; -fx-background-radius: 10; -fx-padding: 10; -fx-font-size: 13px;" HBox.hgrow="ALWAYS" />
                                        <Button text="🎨 Generate" onAction="#generateAvatar" 
                                                style="-fx-background-color: -fx-primary-pink; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 10 20; -fx-cursor: hand;" />
                                        <Button text="📁 Upload" onAction="#handleUploadImage" 
                                                style="-fx-background-color: white; -fx-border-color: #dbe4f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-text-fill: #4a5568; -fx-font-weight: bold; -fx-padding: 10 20; -fx-cursor: hand;" />
                                    </children>
                                </HBox>
                                
                                <Label text="Powered by Pollinations AI &amp; Dicebear" style="-fx-font-size: 11px; -fx-text-fill: #a0aec0;" />
                            </children>
                        </VBox>

                        <Separator style="-fx-opacity: 0.4;" />

                        <!-- Form Fields -->
                        <VBox spacing="18.0">
                            <children>
                                <!-- Username -->
                                <VBox spacing="6.0">
                                    <children>
                                        <Label text="USERNAME" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #a0aec0; -fx-letter-spacing: 1;" />
                                        <TextField fx:id="txtUsername" promptText="Enter username..."
                                                   style="-fx-background-color: white; -fx-border-color: #dbe4f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12; -fx-font-size: 14px;" />
                                    </children>
                                </VBox>

                                <!-- Email -->
                                <VBox spacing="6.0">
                                    <children>
                                        <Label text="EMAIL ADDRESS" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #a0aec0; -fx-letter-spacing: 1;" />
                                        <TextField fx:id="txtEmail" promptText="Enter email..."
                                                   style="-fx-background-color: white; -fx-border-color: #dbe4f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12; -fx-font-size: 14px;" />
                                    </children>
                                </VBox>

                                <!-- Phone -->
                                <VBox spacing="6.0">
                                    <children>
                                        <Label text="PHONE NUMBER" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #a0aec0; -fx-letter-spacing: 1;" />
                                        <TextField fx:id="txtNumtel" promptText="Enter phone number..."
                                                   style="-fx-background-color: white; -fx-border-color: #dbe4f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12; -fx-font-size: 14px;" />
                                    </children>
                                </VBox>

                                <!-- New Password -->
                                <VBox spacing="6.0">
                                    <children>
                                        <Label text="NEW PASSWORD" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #a0aec0; -fx-letter-spacing: 1;" />
                                        <PasswordField fx:id="txtPassword" promptText="Leave blank to keep current password"
                                                       style="-fx-background-color: white; -fx-border-color: #dbe4f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12; -fx-font-size: 14px;" />
                                    </children>
                                </VBox>

                                <!-- Feedback label -->
                                <Label fx:id="lblMessage" text="" wrapText="true"
                                       style="-fx-font-size: 13px; -fx-font-weight: bold;" />
                            </children>
                        </VBox>

                        <Separator style="-fx-opacity: 0.4;" />

                        <!-- Action Buttons -->
                        <HBox alignment="CENTER_RIGHT" spacing="15.0">
                            <children>
                                <Button text="← Cancel" onAction="#goBack"
                                        style="-fx-background-color: white; -fx-border-color: #dbe4f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-text-fill: #4a5568; -fx-font-weight: bold; -fx-padding: 12 24;"
                                        prefHeight="48" />
                                <Button text="💾  Save Changes" onAction="#saveProfile"
                                        styleClass="btn-primary"
                                        prefWidth="200" prefHeight="48" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
                </children>
                </StackPane>
            </content>
        </ScrollPane>
    </children>
</VBox>
