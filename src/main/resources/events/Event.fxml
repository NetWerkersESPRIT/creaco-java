<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER" spacing="22.0" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.Events.EventController">
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
    </padding>
    <children>
        <!-- Header Section -->
        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="top-nav">
            <children>
                <VBox>
                    <children>
                        <Label style="-fx-text-fill: #a0aec0; -fx-font-size: 12px;" text="Pages / Events" />
                        <Label styleClass="title-label" text="Event Management" />
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Button style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 8;">
                            <graphic>
                                <Label style="-fx-font-size: 16px;" text="🔔" />
                            </graphic>
                        </Button>
                        <HBox alignment="CENTER" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 5 15 5 15;">
                            <children>
                                <VBox alignment="CENTER_RIGHT">
                                    <children>
                                        <Label style="-fx-font-size: 10px; -fx-text-fill: -fx-primary-pink; -fx-font-weight: bold;" text="Welcome" />
                                        <Label style="-fx-font-size: 14px; -fx-font-weight: bold;" text="Admin User" />
                                    </children>
                                </VBox>
                                <Label styleClass="badge-pink" text="ADMIN" />
                            </children>
                        </HBox>
                    </children>
                </HBox>
            </children>
        </HBox>

        <HBox spacing="20.0" VBox.vgrow="ALWAYS">
            <children>
                <!-- Form Card -->
                <VBox prefWidth="450.0" spacing="20.0" styleClass="card">
                    <children>
                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -fx-text-main;" text="Event Details" />
                        
                        <GridPane hgap="15.0" vgap="15.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="100.0" />
                                <ColumnConstraints hgrow="ALWAYS" />
                            </columnConstraints>
                            <children>
                                <Label text="Name:" styleClass="subtitle-label" />
                                <TextField fx:id="txtName" promptText="Enter event name" styleClass="search-bar" GridPane.columnIndex="1" />
                                
                                <Label text="Type:" styleClass="subtitle-label" GridPane.rowIndex="1" />
                                <ComboBox fx:id="cbType" promptText="Select type" maxWidth="Infinity" styleClass="search-bar" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                
                                <Label text="Category:" styleClass="subtitle-label" GridPane.rowIndex="2" />
                                <TextField fx:id="txtCategory" promptText="e.g. Technology" styleClass="search-bar" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                
                                <Label text="Date:" styleClass="subtitle-label" GridPane.rowIndex="3" />
                                <DatePicker fx:id="dpDate" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                
                                <Label text="Time:" styleClass="subtitle-label" GridPane.rowIndex="4" />
                                <TextField fx:id="txtTime" promptText="HH:mm" styleClass="search-bar" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                                
                                <Label text="Capacity:" styleClass="subtitle-label" GridPane.rowIndex="5" />
                                <TextField fx:id="txtCapacity" promptText="Max participants" styleClass="search-bar" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                                
                                <Label text="Organizer:" styleClass="subtitle-label" GridPane.rowIndex="6" />
                                <TextField fx:id="txtOrganizer" promptText="Organizer name" styleClass="search-bar" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                            </children>
                        </GridPane>
                        
                        <VBox spacing="8.0">
                            <Label text="Description:" styleClass="subtitle-label" />
                            <TextArea fx:id="txtDescription" prefHeight="100.0" promptText="Event description..." styleClass="search-bar" wrapText="true" />
                        </VBox>
                        
                        <VBox spacing="10.0">
                            <children>
                                <HBox spacing="10.0">
                                    <children>
                                        <Button fx:id="btnAdd" onAction="#addEvent" prefHeight="45.0" styleClass="btn-primary" text="Add Event" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                                        <Button fx:id="btnUpdate" onAction="#updateEvent" prefHeight="45.0" styleClass="btn-primary" text="Update" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-background-color: #2d3748;" />
                                    </children>
                                </HBox>
                                <Button fx:id="btnDelete" onAction="#deleteEvent" prefHeight="45.0" styleClass="btn-primary" text="Delete Selected" maxWidth="Infinity" style="-fx-background-color: #cbd5e0; -fx-text-fill: #4a5568;" />
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <!-- Table Card -->
                <VBox spacing="15.0" styleClass="card" HBox.hgrow="ALWAYS">
                    <children>
                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -fx-text-main;" text="Existing Events" />
                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox fx:id="cardsContainer" spacing="15.0" style="-fx-padding: 5;">
                                    <!-- Cards will be injected here -->
                                </VBox>
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>
