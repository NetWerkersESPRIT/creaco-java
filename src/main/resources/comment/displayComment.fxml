<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>

<VBox spacing="25.0" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.comment.DisplayCommentController">
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
    </padding>
    <children>
        <!-- Back Link -->
        <HBox alignment="CENTER_LEFT">
            <children>
                <Button onAction="#goBackToPosts" style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-font-weight: bold; -fx-font-size: 11px; -fx-cursor: hand;" text="← BACK TO FORUM" />
            </children>
        </HBox>

        <!-- Post Summary Card -->
        <VBox styleClass="card" spacing="15.0">
            <padding>
                <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
            </padding>
            <children>
                <HBox spacing="15.0" alignment="CENTER_LEFT">
                    <children>
                        <StackPane fx:id="postAuthorAvatarContainer" style="-fx-background-color: -fx-primary-gradient; -fx-background-radius: 12; -fx-min-width: 45; -fx-max-width: 45; -fx-min-height: 45; -fx-max-height: 45;">
                            <children>
                                <Label text="“" style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: bold; -fx-padding: 5 0 0 0;" />
                            </children>
                        </StackPane>
                        <Label fx:id="postTitleLabel" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2d3748;" text="Post Title" wrapText="true" />
                    </children>
                </HBox>
                
                <Label fx:id="postMetaLabel" style="-fx-font-size: 12px; -fx-text-fill: #718096;" text="Posted by user • Date" />
                
                <Label fx:id="postContentLabel" style="-fx-font-size: 16px; -fx-text-fill: #4a5568; -fx-line-spacing: 5;" text="Post content..." wrapText="true" />
                
                <Separator style="-fx-opacity: 0.3;" />

                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <Button onAction="#onSharePost" style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-font-weight: bold; -fx-font-size: 12px; -fx-cursor: hand;" text="↪ Share" />
                        <HBox alignment="CENTER" spacing="5.0" style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 20; -fx-padding: 6 15 6 15;">
                            <children>
                                <Label fx:id="likesBadge" text="👍 LIKE 0" style="-fx-font-weight: bold; -fx-text-fill: #64748b; -fx-font-size: 11px;" />
                            </children>
                        </HBox>
                        <HBox alignment="CENTER" spacing="5.0" style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 20; -fx-padding: 6 15 6 15;">
                            <children>
                                <Label fx:id="repliesBadge" text="💬 0 REPLIES" style="-fx-font-weight: bold; -fx-text-fill: #64748b; -fx-font-size: 11px;" />
                            </children>
                        </HBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox spacing="10.0" alignment="CENTER_RIGHT">
                            <children>
                                <Button onAction="#onPinPost" style="-fx-background-color: #f8fafc; -fx-background-radius: 50; -fx-min-width: 35; -fx-max-width: 35; -fx-min-height: 35; -fx-max-height: 35; -fx-cursor: hand;" text="📌" />
                                <Button onAction="#onLockPost" style="-fx-background-color: #f8fafc; -fx-background-radius: 50; -fx-min-width: 35; -fx-max-width: 35; -fx-min-height: 35; -fx-max-height: 35; -fx-cursor: hand;" text="🔒" />
                                <Button fx:id="btnEditPost" onAction="#onEditPost" style="-fx-background-color: #f8fafc; -fx-background-radius: 50; -fx-min-width: 35; -fx-max-width: 35; -fx-min-height: 35; -fx-max-height: 35; -fx-cursor: hand;" text="📝" />
                                <Button fx:id="btnDeletePost" onAction="#onDeletePost" style="-fx-background-color: #f8fafc; -fx-background-radius: 50; -fx-min-width: 35; -fx-max-width: 35; -fx-min-height: 35; -fx-max-height: 35; -fx-cursor: hand;" text="🗑" />
                            </children>
                        </HBox>
                    </children>
                </HBox>
            </children>
        </VBox>

        <!-- Discussion / Comments Card (Instagram-style white) -->
        <VBox style="-fx-background-color: white; -fx-background-radius: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 20, 0, 0, 4);" spacing="0" VBox.vgrow="ALWAYS">

            <!-- Header row -->
            <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-padding: 18 20 12 20; -fx-border-color: transparent transparent #e2e8f0 transparent; -fx-border-width: 0 0 1 0;">
                <children>
                    <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;" text="Comments" />
                    <Label fx:id="repliesBadge" text="" style="-fx-font-size: 12px; -fx-text-fill: #94a3b8;" />
                </children>
            </HBox>

            <!-- Comment Feed -->
            <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true"
                        style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
                <content>
                    <VBox fx:id="commentsContainer" spacing="0" style="-fx-padding: 8 16 8 16;">
                        <children>
                            <!-- Empty State -->
                            <VBox fx:id="emptyState" alignment="CENTER" spacing="12.0" style="-fx-padding: 50 0 50 0;">
                                <children>
                                    <Label text="💬" style="-fx-font-size: 36px; -fx-text-fill: #3a3a3c;" />
                                    <Label text="No comments yet" style="-fx-font-size: 14px; -fx-text-fill: #636366; -fx-font-weight: bold;" />
                                    <Label text="Be the first to share your thoughts!" style="-fx-font-size: 12px; -fx-text-fill: #48484a;" />
                                </children>
                            </VBox>
                        </children>
                    </VBox>
                </content>
            </ScrollPane>

            <!-- GIF Attachment Preview -->
            <HBox fx:id="attachmentPreview" alignment="CENTER_LEFT" managed="false" spacing="10.0"
                  style="-fx-padding: 8 20 4 20; -fx-background-color: #f8fafc;" visible="false">
                <children>
                    <StackPane style="-fx-background-radius: 10;">
                        <children>
                            <ImageView fx:id="gifPreview" fitHeight="70.0" fitWidth="70.0" preserveRatio="true" />
                            <Button onAction="#removeAttachment"
                                    style="-fx-background-color: rgba(0,0,0,0.6); -fx-text-fill: white; -fx-background-radius: 50; -fx-min-width: 18; -fx-max-width: 18; -fx-min-height: 18; -fx-max-height: 18; -fx-font-size: 9px; -fx-cursor: hand;"
                                    text="✕" StackPane.alignment="TOP_RIGHT">
                                <StackPane.margin><Insets right="-4.0" top="-4.0" /></StackPane.margin>
                            </Button>
                        </children>
                    </StackPane>
                    <Label style="-fx-text-fill: #8e8e8e; -fx-font-size: 11px;" text="GIF attached" />
                </children>
            </HBox>

            <!-- Bottom Instagram-style input bar -->
            <HBox alignment="CENTER" spacing="10.0"
                  style="-fx-padding: 10 16 14 16; -fx-border-color: #e2e8f0 transparent transparent transparent; -fx-border-width: 1 0 0 0;">
                <children>
                    <!-- Current User Avatar -->
                    <StackPane fx:id="currentUserAvatarContainer" />

                    <!-- Pill text field with Emoji and GIF inside -->
                    <HBox alignment="CENTER" spacing="8.0" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #f1f5f9; -fx-background-radius: 22; -fx-padding: 8 14 8 14;">
                        <children>
                            <!-- Emoji Button inside pill -->
                            <Button onAction="#openEmojiPicker"
                                    style="-fx-background-color: transparent; -fx-font-size: 18px; -fx-cursor: hand; -fx-padding: 0;"
                                    text="😊" />

                            <TextArea fx:id="commentArea" prefHeight="32.0" maxHeight="80.0"
                                      promptText="Add a comment..."
                                      style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent; -fx-text-fill: #1a1a2e; -fx-font-size: 13px; -fx-prompt-text-fill: #94a3b8;"
                                      wrapText="true" HBox.hgrow="ALWAYS" />

                            <!-- GIF inside pill -->
                            <Button onAction="#openGifPicker"
                                    style="-fx-background-color: #e2e8f0; -fx-background-radius: 8; -fx-text-fill: #64748b; -fx-font-weight: bold; -fx-font-size: 11px; -fx-padding: 4 8; -fx-cursor: hand;"
                                    text="GIF" />
                        </children>
                    </HBox>

                    <!-- Post Button -->
                    <Button onAction="#addComment"
                            style="-fx-background-color: transparent; -fx-text-fill: #3897f0; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand; -fx-padding: 0;"
                            text="Post" />
                </children>
            </HBox>
        </VBox>
    </children>
</VBox>
