<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.collabrequest.ListCollabRequestController" prefWidth="800.0" prefHeight="600.0">
    <children>
        <Label text="Collaboration Requests">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>
        <TableView fx:id="requestTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="idColumn" prefWidth="50.0" text="ID" />
                <TableColumn fx:id="titleColumn" prefWidth="250.0" text="Title" />
                <TableColumn fx:id="budgetColumn" prefWidth="150.0" text="Budget" />
                <TableColumn fx:id="statusColumn" prefWidth="150.0" text="Status" />
                <TableColumn fx:id="collaboratorIdColumn" prefWidth="100.0" text="Collab ID" />
            </columns>
        </TableView>
        <HBox spacing="10.0" alignment="CENTER_RIGHT">
            <children>
                <Button mnemonicParsing="false" onAction="#refreshTable" text="Refresh" />
                <Button mnemonicParsing="false" onAction="#handleAdd" text="New Request" style="-fx-background-color: #2ecc71; -fx-text-fill: white;" />
                <Button mnemonicParsing="false" onAction="#handleEdit" text="Edit Selected" style="-fx-background-color: #3498db; -fx-text-fill: white;" />
                <Button mnemonicParsing="false" onAction="#handleDelete" text="Delete Selected" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" />
            </children>
        </HBox>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
