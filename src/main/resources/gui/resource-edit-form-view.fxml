<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import java.lang.String?>
<?import javafx.collections.FXCollections?>

<VBox alignment="TOP_CENTER" spacing="18.0" styleClass="main-container" prefHeight="760.0" prefWidth="1280.0"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.CourseResourceFormController">
    <padding>
        <Insets bottom="20.0" left="24.0" right="24.0" top="20.0" />
    </padding>
    <children>
        <HBox styleClass="top-nav" alignment="CENTER_LEFT" spacing="15.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Button onAction="#onCancel" text="⬅" styleClass="btn-action-light" style="-fx-padding: 8 12; -fx-background-radius: 12; -fx-font-size: 16px;" />
                    <VBox>
                        <Label style="-fx-text-fill: #a0aec0; -fx-font-size: 10px;" text="Pages / Courses / Resource" />
                        <Label fx:id="titleLabel" styleClass="title-label" text="Add New Resource" />
                        <Label fx:id="subtitleLabel" style="-fx-text-fill: -fx-primary-pink; -fx-font-size: 9px;" text="Fill in the resource details below" />
                    </VBox>
                </HBox>
                <Region HBox.hgrow="ALWAYS" />
            </children>
        </HBox>
        
        <VBox maxWidth="860.0" spacing="20.0" styleClass="card">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
            <children>
                <VBox spacing="4.0">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #334155;" text="Name *" />
                        <TextField fx:id="nameField" promptText="Resource name" />
                        <Label fx:id="nameErrorLabel" text="" style="-fx-text-fill: #b91c1c; -fx-font-size: 10px;" visible="false" managed="false" />
                    </children>
                </VBox>
                <VBox spacing="8.0">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #334155;" text="Type" />
                        <ComboBox fx:id="typeComboBox" prefWidth="250.0">
                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                    <String fx:value="Video" />
                                    <String fx:value="PDF" />
                                    <String fx:value="Link" />
                                    <String fx:value="Document" />
                                </FXCollections>
                            </items>
                        </ComboBox>
                    </children>
                </VBox>
                <VBox spacing="8.0">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #334155;" text="Resource File" />
                        <StackPane onMouseClicked="#onUploadFile" style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-style: dashed; -fx-border-width: 2; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 20; -fx-cursor: hand;">
                            <children>
                                <VBox alignment="CENTER" spacing="8">
                                    <children>
                                        <Label text="📁" style="-fx-font-size: 24px;" />
                                        <Label fx:id="uploadStatusLabel" text="Click to upload or drag and drop" style="-fx-text-fill: #64748b; -fx-font-size: 13px;" />
                                        <Label fx:id="fileUrlLabel" text="No file selected" style="-fx-text-fill: -fx-primary-pink; -fx-font-size: 11px; -fx-font-weight: bold;" wrapText="true" />
                                    </children>
                                </VBox>
                            </children>
                        </StackPane>
                        <!-- Hidden field to store the URL for saving -->
                        <TextField fx:id="urlField" visible="false" managed="false" />
                    </children>
                </VBox>
                <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-text-fill: #334155;" text="Content / Description" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button fx:id="btnParaphrase" onAction="#onParaphrase" text="✨ Paraphrase" styleClass="btn-action-light" style="-fx-font-size: 10px; -fx-padding: 4 8;" />
                            </children>
                        </HBox>
                        <TextArea fx:id="contentArea" prefHeight="150.0" promptText="Enter resource description or text content..." wrapText="true" />
                    </children>
                </VBox>
                <HBox alignment="CENTER_RIGHT" spacing="12.0">
                    <children>
                        <Button mnemonicParsing="false" onAction="#onSave"
                                styleClass="btn-primary" prefWidth="150" prefHeight="40"
                                text="Save resource" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>
