<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="760.0" prefWidth="1280.0" styleClass="main-container"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gui.FrontMainController" stylesheets="@styles.css">

    <left>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="sidebar-container" prefWidth="255.0">
            <content>
                <VBox prefWidth="240.0" spacing="25.0" styleClass="sidebar">
                    <padding>
                        <Insets bottom="30.0" left="24.0" right="24.0" top="30.0" />
                    </padding>
                    <children>
                        <HBox spacing="10.0" alignment="CENTER_LEFT">
                            <Label styleClass="sidebar-brand" text="CreaCo" />
                        </HBox>
                        
                        <VBox spacing="12.0">
                            <Button mnemonicParsing="false" onAction="#onGoToDashboard" prefWidth="210.0" styleClass="sidebar-item sidebar-item-active">
                                <graphic>
                                    <HBox spacing="15.0" alignment="CENTER_LEFT">
                                        <StackPane styleClass="sidebar-icon-box">
                                            <Label text="🏠" style="-fx-font-size: 16px;" />
                                        </StackPane>
                                        <Label text="Dashboard" />
                                    </HBox>
                                </graphic>
                            </Button>
                        </VBox>

                        <Label styleClass="section-header" text="WORKFLOW MANAGEMENT" />
                        <VBox spacing="10.0">
                            <Button fx:id="btnIdeas" mnemonicParsing="false" onAction="#onShowIdeas" prefWidth="210.0" styleClass="sidebar-item">
                                <graphic>
                                    <HBox spacing="15.0" alignment="CENTER_LEFT">
                                        <StackPane styleClass="sidebar-icon-box">
                                            <Label text="💡" style="-fx-font-size: 16px;" />
                                        </StackPane>
                                        <Label text="Ideas" />
                                    </HBox>
                                </graphic>
                            </Button>
                            <Button fx:id="btnMissions" mnemonicParsing="false" onAction="#onShowMissions" prefWidth="210.0" styleClass="sidebar-item">
                                <graphic>
                                    <HBox spacing="15.0" alignment="CENTER_LEFT">
                                        <StackPane styleClass="sidebar-icon-box">
                                            <Label text="💼" style="-fx-font-size: 16px;" />
                                        </StackPane>
                                        <Label text="Missions" />
                                    </HBox>
                                </graphic>
                            </Button>
                            <Button fx:id="btnTasks" mnemonicParsing="false" onAction="#onShowTasks" prefWidth="210.0" styleClass="sidebar-item">
                                <graphic>
                                    <HBox spacing="15.0" alignment="CENTER_LEFT">
                                        <StackPane styleClass="sidebar-icon-box">
                                            <Label text="✅" style="-fx-font-size: 16px;" />
                                        </StackPane>
                                        <Label text="Tasks" />
                                    </HBox>
                                </graphic>
                            </Button>
                        </VBox>

                        <Label styleClass="section-header" text="COMMUNITY &amp; LEARNING" />
                        <VBox spacing="10.0">
                            <Button fx:id="btnEvents" mnemonicParsing="false" onAction="#onShowEvents" prefWidth="210.0" styleClass="sidebar-item">
                                <graphic>
                                    <HBox spacing="15.0" alignment="CENTER_LEFT">
                                        <StackPane styleClass="sidebar-icon-box">
                                            <Label text="📅" style="-fx-font-size: 16px;" />
                                        </StackPane>
                                        <Label text="Events" />
                                    </HBox>
                                </graphic>
                            </Button>
                            <Button fx:id="btnForum" mnemonicParsing="false" onAction="#showForum" prefWidth="210.0" styleClass="sidebar-item">
                                <graphic>
                                    <HBox spacing="15.0" alignment="CENTER_LEFT">
                                        <StackPane styleClass="sidebar-icon-box">
                                            <Label text="💬" style="-fx-font-size: 16px;" />
                                        </StackPane>
                                        <Label text="Forum" />
                                    </HBox>
                                </graphic>
                            </Button>
                            <Button fx:id="btnCollaborations" mnemonicParsing="false" onAction="#onShowCollaborations" prefWidth="210.0" styleClass="sidebar-item">
                                <graphic>
                                    <HBox spacing="15.0" alignment="CENTER_LEFT">
                                        <StackPane styleClass="sidebar-icon-box">
                                            <Label text="🤝" style="-fx-font-size: 16px;" />
                                        </StackPane>
                                        <Label text="Collaborations" />
                                    </HBox>
                                </graphic>
                            </Button>
                            <Button fx:id="btnCourses" mnemonicParsing="false" onAction="#onShowCourses" prefWidth="210.0" styleClass="sidebar-item">
                                <graphic>
                                    <HBox spacing="15.0" alignment="CENTER_LEFT">
                                        <StackPane styleClass="sidebar-icon-box">
                                            <Label text="🎓" style="-fx-font-size: 16px;" />
                                        </StackPane>
                                        <Label text="Courses" />
                                    </HBox>
                                </graphic>
                            </Button>
                        </VBox>

                        <Label fx:id="lblAdminHeader" styleClass="section-header" text="ADMINISTRATION" />
                        <VBox fx:id="boxAdmin" spacing="10.0">
                            <children>
                                <Button fx:id="btnAdmin" mnemonicParsing="false" onAction="#onShowAdmin" prefWidth="210.0" styleClass="sidebar-item">
                                    <graphic>
                                        <HBox spacing="15.0" alignment="CENTER_LEFT">
                                            <StackPane styleClass="sidebar-icon-box">
                                                <Label text="🛠" style="-fx-font-size: 16px;" />
                                            </StackPane>
                                            <Label text="Admin Panel" />
                                        </HBox>
                                    </graphic>
                                </Button>
                            </children>
                        </VBox>

                        <Region VBox.vgrow="ALWAYS" />
                        <Button onAction="#logout" text="Log Out" prefHeight="45.0" prefWidth="200.0" styleClass="btn-primary" />
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </left>

    <center>
        <StackPane fx:id="contentArea">
            <children>
                <VBox fx:id="dashboardView" spacing="22.0">
                    <padding>
                        <Insets top="24" left="24" right="24" bottom="24"/>
                    </padding>
                    <children>
                        <HBox fx:id="previewBanner" alignment="CENTER_LEFT" spacing="15" visible="false" managed="false"
                              style="-fx-background-color: #fef08a; -fx-padding: 12 24; -fx-background-radius: 8;">
                            <Label text="You are now in preview mode" style="-fx-font-weight: bold; -fx-text-fill: #854d0e; -fx-font-size: 14;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button text="Exit Preview" onAction="#exitPreview"
                                    style="-fx-background-color: #ca8a04; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6;" />
                        </HBox>

                        <HBox styleClass="top-nav" alignment="CENTER_LEFT" spacing="15.0">
                            <children>
                                <VBox>
                                    <Label style="-fx-text-fill: #a0aec0; -fx-font-size: 12px;" text="Pages / Dashboard" />
                                    <Label fx:id="txtWelcome" styleClass="title-label" text="Explore" />
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <TextField fx:id="searchField" promptText="Search courses..." styleClass="search-bar" prefWidth="280.0" />
                                <Button onAction="#onShowProfile" styleClass="btn-logout" style="-fx-background-color: #2d3748;">
                                    <graphic>
                                        <Label text="👤" style="-fx-text-fill: white; -fx-font-size: 16px;" />
                                    </graphic>
                                </Button>
                            </children>
                        </HBox>

                        <ScrollPane fitToWidth="true"
                                    hbarPolicy="NEVER"
                                    style="-fx-background: transparent; -fx-background-color: transparent;"
                                    VBox.vgrow="ALWAYS">
                            <content>
                                <TilePane fx:id="coursesContainer"
                                          hgap="20"
                                          vgap="20"
                                          prefTileWidth="340"
                                          alignment="TOP_CENTER"
                                          style="-fx-padding: 10;">
                                </TilePane>
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </center>

</BorderPane>