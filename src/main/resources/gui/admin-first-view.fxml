<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.image.ImageView?>

<StackPane fx:id="rootStackPane" prefHeight="760.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.HelpDeskMessagesController" stylesheets="@styles.css">
    <BorderPane styleClass="main-container">
        <!-- Sidebar Navigation -->
        <left>
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="sidebar-container" prefWidth="255.0">
                <content>
                    <VBox prefWidth="240.0" spacing="25.0" styleClass="sidebar">
                        <padding>
                            <Insets bottom="30.0" left="24.0" right="24.0" top="30.0" />
                        </padding>
                        <children>
                            <HBox spacing="10.0" alignment="CENTER_LEFT">
                                <Label styleClass="sidebar-brand" text="CreaCo Admin" />
                            </HBox>
                            
                            <VBox spacing="12.0">
                                <Button fx:id="btnDashboard" mnemonicParsing="false" onAction="#onShowDashboard" prefWidth="210.0" styleClass="sidebar-item sidebar-item-active">
                                    <graphic>
                                        <HBox spacing="15.0" alignment="CENTER_LEFT">
                                            <StackPane styleClass="sidebar-icon-box-active">
                                                <Label text="🏠" style="-fx-font-size: 16px; -fx-text-fill: white;" />
                                            </StackPane>
                                            <Label text="Admin Dashboard" />
                                        </HBox>
                                    </graphic>
                                </Button>
                            </VBox>

                            <Label styleClass="section-header" text="MANAGEMENT" />
                            <VBox spacing="10.0">
                                <children>
                                    <Button fx:id="btnUsers" mnemonicParsing="false" onAction="#onShowUsers" prefWidth="210.0" styleClass="sidebar-item">
                                        <graphic>
                                            <HBox spacing="15.0" alignment="CENTER_LEFT">
                                                <StackPane styleClass="sidebar-icon-box">
                                                    <Label text="👤" style="-fx-font-size: 16px;" />
                                                </StackPane>
                                                <Label text="Users Control" />
                                            </HBox>
                                        </graphic>
                                    </Button>
                                    <Button fx:id="btnModeration" mnemonicParsing="false" onAction="#onShowModeration" prefWidth="210.0" styleClass="sidebar-item">
                                        <graphic>
                                            <HBox spacing="15.0" alignment="CENTER_LEFT">
                                                <StackPane styleClass="sidebar-icon-box">
                                                    <Label text="✓" style="-fx-font-size: 16px;" />
                                                </StackPane>
                                                <Label text="Moderation" />
                                            </HBox>
                                        </graphic>
                                    </Button>
                                    <Button fx:id="btnForum" mnemonicParsing="false" onAction="#onShowForum" prefWidth="210.0" styleClass="sidebar-item">
                                        <graphic>
                                            <HBox spacing="15.0" alignment="CENTER_LEFT">
                                                <StackPane styleClass="sidebar-icon-box">
                                                    <Label text="📊" style="-fx-font-size: 16px;" />
                                                </StackPane>
                                                <Label text="Forum" />
                                            </HBox>
                                        </graphic>
                                    </Button>
                                    <Button fx:id="btnCourses" mnemonicParsing="false" onAction="#onShowCourses" prefWidth="210.0" styleClass="sidebar-item">
                                        <graphic>
                                            <HBox spacing="15.0" alignment="CENTER_LEFT">
                                                <StackPane styleClass="sidebar-icon-box">
                                                    <Label text="🎓" style="-fx-font-size: 16px;" />
                                                </StackPane>
                                                <Label text="Courses" />
                                            </HBox>
                                        </graphic>
                                    </Button>
                                </children>
                            </VBox>

                            <Region VBox.vgrow="ALWAYS" />
                            
                            <Button mnemonicParsing="false" onAction="#logout" prefWidth="210.0" styleClass="sidebar-item">
                                <graphic>
                                    <HBox spacing="15.0" alignment="CENTER_LEFT">
                                        <StackPane styleClass="sidebar-icon-box">
                                            <Label text="🏃" style="-fx-font-size: 16px;" />
                                        </StackPane>
                                        <Label text="Logout" />
                                    </HBox>
                                </graphic>
                            </Button>
                        </children>
                    </VBox>
                </content>
            </ScrollPane>
        </left>

        <!-- Main Content Area -->
        <center>
            <VBox spacing="0">
                <children>
                    <!-- Top Navigation / Header -->
                    <VBox spacing="10">
                        <padding>
                            <Insets top="24" left="24" right="24" bottom="24"/>
                        </padding>
                        <children>
                            <HBox styleClass="top-nav" alignment="CENTER_LEFT" spacing="20.0">
                                <children>
                                    <VBox>
                                        <Label fx:id="lblBreadcrumb" style="-fx-text-fill: #a0aec0; -fx-font-size: 11px;" text="Pages / Admin / Dashboard" />
                                        <Label fx:id="lblTitle" styleClass="title-label" text="Admin Workspace" style="-fx-font-size: 20px;"/>
                                    </VBox>
                                    <Region HBox.hgrow="ALWAYS" />
                                    
                                    <!-- Header Card (Profile) -->
                                    <HBox alignment="CENTER" spacing="15" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 10 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 4);">
                                        <children>
                                            <VBox alignment="CENTER_RIGHT">
                                                <Label fx:id="lblAdminName" text="Admin User" style="-fx-text-fill: -fx-text-main; -fx-font-weight: bold; -fx-font-size: 14px;" />
                                                <Label text="System Administrator" style="-fx-text-fill: -fx-primary-pink; -fx-font-size: 10px; -fx-font-weight: bold;" />
                                            </VBox>
                                            <StackPane style="-fx-background-color: #f1f5f9; -fx-background-radius: 12; -fx-padding: 2;">
                                                <children>
                                                    <ImageView fx:id="imgAdminAvatar" fitHeight="36" fitWidth="36" pickOnBounds="true" preserveRatio="true">
                                                        <clip>
                                                            <Circle centerX="18" centerY="18" radius="18" />
                                                        </clip>
                                                    </ImageView>
                                                </children>
                                            </StackPane>
                                        </children>
                                    </HBox>
                                </children>
                            </HBox>
                        </children>
                    </VBox>

                    <!-- Dynamic Content Container -->
                    <StackPane fx:id="mainContentContainer" VBox.vgrow="ALWAYS">
                        <padding>
                            <Insets bottom="0" left="0" right="0" top="0" />
                        </padding>
                        <!-- Start with a blank or welcome state -->
                        <children>
                            <VBox alignment="CENTER" spacing="20">
                                <children>
                                    <Label text="Welcome to Admin Dashboard" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />
                                    <Label text="Select a module from the sidebar to begin." style="-fx-text-fill: #64748b; -fx-font-size: 14px;" />
                                </children>
                            </VBox>
                        </children>
                    </StackPane>
                </children>
            </VBox>
        </center>
    </BorderPane>
</StackPane>
