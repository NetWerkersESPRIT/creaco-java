<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="25.0" styleClass="main-container" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.collab.manager.ContractListController">
    <stylesheets>
        <URL value="@../../styles.css" />
    </stylesheets>
    <children>


        <!-- Main Content Card -->
        <VBox spacing="20.0" styleClass="card" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label styleClass="card-title" text="Legal Agreements &amp; Protocols" />
                                <Label text="Monitoring signature status and contract lifecycle velocity." styleClass="card-subtitle" />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                            <children>
                                <TextField fx:id="searchField" prefWidth="250.0" promptText="Search ref, project, partner..." styleClass="search-field" />
                                <ComboBox fx:id="statusFilter" prefWidth="150.0" styleClass="filter-combo" />
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <!-- Column Headers -->
                <HBox spacing="20.0" styleClass="list-header" style="-fx-padding: 15 20;">
                    <children>
                        <Label prefWidth="180" text="REFERENCE" />
                        <Label prefWidth="250" text="PROJECT / PARTNER" />
                        <Label prefWidth="150" text="AMOUNT" />
                        <Label prefWidth="150" text="STATUS" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label prefWidth="100" text="ACTION" />
                    </children>
                </HBox>

                <!-- Scrollable List -->
                <ListView fx:id="contractListView" styleClass="modern-list-view" VBox.vgrow="ALWAYS" />
            </children>
        </VBox>
    </children>
</VBox>
