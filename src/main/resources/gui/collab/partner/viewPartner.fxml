<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox spacing="30.0" styleClass="main-container" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.collab.partner.ViewPartnerController">
    <stylesheets>
        <URL value="@../../styles.css" />
    </stylesheets>
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
    <children>
        <!-- Partner Profile Card -->
        <VBox prefWidth="420.0" spacing="30.0" styleClass="card" HBox.hgrow="NEVER">
            <children>
                <Label styleClass="card-title" text="Partner Profile" />

                <!-- Profile Header -->
                <VBox alignment="CENTER" spacing="15.0">
                    <children>
                        <VBox alignment="CENTER" maxHeight="100.0" maxWidth="100.0" minHeight="100.0" minWidth="100.0" style="-fx-background-color: #f1f5f9; -fx-background-radius: 50; -fx-border-color: #e2e8f0; -fx-border-radius: 50;">
                            <children>
                                <Label text="🏢" style="-fx-font-size: 40px;" />
                            </children>
                        </VBox>
                        <VBox alignment="CENTER" spacing="5.0">
                            <children>
                                <Label fx:id="pCompanyLabel" styleClass="title-label" style="-fx-font-size: 24px;" text="Amazon" />
                                <Label fx:id="pDomainLabel" styleClass="card-subtitle" style="-fx-font-size: 14px;" text="E-commerce" />
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <!-- Profile Details -->
                <VBox spacing="20.0">
                    <children>
                        <HBox spacing="10.0">
                            <children>
                                <Label prefWidth="90.0" styleClass="form-label" text="Name :" />
                                <Label fx:id="pNameLabel" styleClass="card-subtitle" style="-fx-text-fill: #64748b; -fx-font-size: 14px;" text="Alex" />
                            </children>
                        </HBox>
                        <HBox spacing="10.0">
                            <children>
                                <Label prefWidth="90.0" styleClass="form-label" text="Email :" />
                                <Label fx:id="pEmailLabel" styleClass="card-subtitle" style="-fx-text-fill: #64748b; -fx-font-size: 14px;" text="alex@yahoo.fr" />
                            </children>
                        </HBox>
                        <HBox spacing="10.0">
                            <children>
                                <Label prefWidth="90.0" styleClass="form-label" text="Phone :" />
                                <Label fx:id="pPhoneLabel" styleClass="card-subtitle" style="-fx-text-fill: #64748b; -fx-font-size: 14px;" text="987765345" />
                            </children>
                        </HBox>
                        <HBox spacing="10.0">
                            <children>
                                <Label prefWidth="90.0" styleClass="form-label" text="Website :" />
                                <Label fx:id="pWebsiteLabel" styleClass="action-link" style="-fx-font-size: 14px;" text="www.amazon.fr" />
                            </children>
                        </HBox>
                        <HBox spacing="10.0">
                            <children>
                                <Label prefWidth="90.0" styleClass="form-label" text="Address :" />
                                <Label fx:id="pAddressLabel" styleClass="card-subtitle" style="-fx-text-fill: #64748b; -fx-font-size: 14px;" text="France" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <!-- Profile Actions -->
                <HBox spacing="15.0">
                    <children>
                        <Button onAction="#onEdit" prefHeight="40.0" prefWidth="100.0" styleClass="btn, btn-secondary" text="EDIT" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#onDelete" prefHeight="40.0" prefWidth="100.0" styleClass="btn, btn-delete" text="DELETE" />
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets bottom="35.0" left="35.0" right="35.0" top="35.0" />
            </padding>
        </VBox>

        <!-- Requests History Card -->
        <VBox minHeight="550.0" spacing="25.0" styleClass="card" HBox.hgrow="ALWAYS">
            <children>
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <Label styleClass="card-title" text="Requests History" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Hyperlink onAction="#onNewRequest" styleClass="action-link" style="-fx-font-size: 13px;" text="New request" />
                    </children>
                </HBox>

                <TableView fx:id="requestsTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colTitle" prefWidth="300.0" text="TITLE" />
                        <TableColumn fx:id="colStatus" prefWidth="150.0" text="STATUS" />
                        <TableColumn fx:id="colPeriod" prefWidth="250.0" text="PERIOD" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
            <padding>
                <Insets bottom="35.0" left="35.0" right="35.0" top="35.0" />
            </padding>
        </VBox>
    </children>
</HBox>
