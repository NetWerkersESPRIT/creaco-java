<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>

<HBox spacing="30.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.collab.partner.ViewPartnerController" style="-fx-background-color: transparent;">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
    <children>
        <!-- Partner Profile Card -->
        <VBox spacing="25.0" styleClass="card" HBox.hgrow="NEVER" prefWidth="420" minHeight="550">
            <children>
                <Label styleClass="card-title" text="Partner Profile" />

                <VBox alignment="CENTER" spacing="12.0">
                    <children>
                        <VBox alignment="CENTER" minWidth="100" minHeight="100" maxWidth="100" maxHeight="100" style="-fx-background-color: #f1f5f9; -fx-background-radius: 50; -fx-border-color: #e2e8f0; -fx-border-radius: 50; -fx-border-width: 1;">
                            <children>
                                <Label text="🏢" style="-fx-font-size: 40px;" />
                            </children>
                        </VBox>
                        <VBox alignment="CENTER" spacing="2.0">
                            <children>
                                <Label fx:id="pCompanyLabel" text="Amazon" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />
                                <Label fx:id="pDomainLabel" text="E-commerce" style="-fx-text-fill: #94a3b8; -fx-font-size: 14px;" />
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <VBox spacing="18.0" style="-fx-padding: 10 0 0 0;">
                    <children>
                        <HBox spacing="10.0">
                            <children>
                                <Label text="Name :" prefWidth="90" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 14px;" />
                                <Label fx:id="pNameLabel" text="Alex" style="-fx-text-fill: #64748b; -fx-font-size: 14px;" />
                            </children>
                        </HBox>
                        <HBox spacing="10.0">
                            <children>
                                <Label text="Email :" prefWidth="90" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 14px;" />
                                <Label fx:id="pEmailLabel" text="alex@yahoo.fr" style="-fx-text-fill: #64748b; -fx-font-size: 14px;" />
                            </children>
                        </HBox>
                        <HBox spacing="10.0">
                            <children>
                                <Label text="Phone :" prefWidth="90" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 14px;" />
                                <Label fx:id="pPhoneLabel" text="987765345" style="-fx-text-fill: #64748b; -fx-font-size: 14px;" />
                            </children>
                        </HBox>
                        <HBox spacing="10.0">
                            <children>
                                <Label text="Website :" prefWidth="90" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 14px;" />
                                <Label fx:id="pWebsiteLabel" text="www.amazon.fr" style="-fx-text-fill: -fx-primary-pink; -fx-font-weight: bold; -fx-font-size: 14px;" />
                            </children>
                        </HBox>
                        <HBox spacing="10.0">
                            <children>
                                <Label text="Address :" prefWidth="90" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 14px;" />
                                <Label fx:id="pAddressLabel" text="France" style="-fx-text-fill: #64748b; -fx-font-size: 14px;" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <HBox spacing="15.0">
                    <children>
                        <Button onAction="#onEdit" text="EDIT" style="-fx-background-color: #94a3b8; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 10 25; -fx-font-weight: bold; -fx-cursor: hand;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#onDelete" text="DELETE" style="-fx-background-color: #f43f5e; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 10 25; -fx-font-weight: bold; -fx-cursor: hand;" />
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
        </VBox>

        <!-- Requests History Card -->
        <VBox spacing="25.0" styleClass="card" HBox.hgrow="ALWAYS" minHeight="550">
            <children>
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <Label styleClass="card-title" text="Requests History" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Hyperlink onAction="#onNewRequest" text="New request" style="-fx-text-fill: -fx-primary-pink; -fx-font-weight: bold; -fx-font-size: 13px; -fx-underline: false;" />
                    </children>
                </HBox>

                <TableView fx:id="requestsTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
                    <columns>
                        <TableColumn fx:id="colTitle" text="TITLE" prefWidth="300" />
                        <TableColumn fx:id="colStatus" text="STATUS" prefWidth="150" />
                        <TableColumn fx:id="colPeriod" text="PERIOD" prefWidth="250" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
        </VBox>
    </children>
</HBox>
