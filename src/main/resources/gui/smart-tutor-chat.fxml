<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<VBox prefHeight="600.0" prefWidth="450.0" spacing="0" 
      style="-fx-background-color: white; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: #e2e8f0; -fx-border-width: 1;" 
      stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="gui.SmartTutorChatController">
    
    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: linear-gradient(to right, #6c2db1, #ec4899); -fx-padding: 20; -fx-background-radius: 20 20 0 0;">
        <children>
            <StackPane>
                <Circle fill="WHITE" radius="18" opacity="0.2" />
                <Label text="✨" style="-fx-font-size: 18px;" />
            </StackPane>
            <VBox>
                <Label fx:id="titleLabel" text="Smart Tutor" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: white;" />
                <Label text="Online | AI Assistant" style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.8);" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#closeDialog" styleClass="btn-action-light" text="✕" 
                    style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" />
        </children>
    </HBox>

    <!-- Chat Area -->
    <ScrollPane fx:id="chatScroll" fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS" 
                style="-fx-background-color: #f8fafc; -fx-background: #f8fafc;">
        <content>
            <VBox fx:id="chatBox" spacing="15" style="-fx-padding: 20;" />
        </content>
    </ScrollPane>

    <!-- Input Area -->
    <HBox spacing="10" style="-fx-padding: 20; -fx-background-color: white; -fx-background-radius: 0 0 20 20; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0;">
        <children>
            <TextField fx:id="chatInput" onAction="#sendChatMessage" promptText="Type your message..." 
                       HBox.hgrow="ALWAYS" styleClass="search-bar" 
                       style="-fx-background-radius: 20; -fx-padding: 10 15; -fx-background-color: #f1f5f9;" />
            <Button onAction="#sendChatMessage" styleClass="btn-primary" text="Send" 
                    style="-fx-background-color: #6c2db1; -fx-background-radius: 20; -fx-padding: 10 20; -fx-font-weight: bold;" />
        </children>
    </HBox>
</VBox>
