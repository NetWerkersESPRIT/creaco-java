<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.HTMLEditor?>

<VBox alignment="TOP_CENTER" spacing="18.0" styleClass="main-container" prefHeight="760.0" prefWidth="1280.0"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.CourseCategoryFormController">
    <padding>
        <Insets bottom="20.0" left="24.0" right="24.0" top="20.0" />
    </padding>
    <children>
        <HBox styleClass="top-nav" alignment="CENTER_LEFT" spacing="15.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Button onAction="#onCancel" text="⬅" styleClass="btn-action-light" style="-fx-padding: 8 12; -fx-background-radius: 12; -fx-font-size: 16px;" />
                    <VBox>
                        <Label style="-fx-text-fill: #a0aec0; -fx-font-size: 10px;" text="Pages / Categories" />
                        <Label fx:id="titleLabel" styleClass="title-label" text="Edit Category" />
                        <Label fx:id="subtitleLabel" style="-fx-text-fill: -fx-primary-pink; -fx-font-size: 9px;" text="Modify the category details below" />
                    </VBox>
                </HBox>
                <Region HBox.hgrow="ALWAYS" />
            </children>
        </HBox>
        
        <VBox maxWidth="860.0" spacing="20.0" styleClass="card">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
            <children>
                <VBox spacing="4.0">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #334155;" text="Name *" />
                        <TextField fx:id="nameField" promptText="Category name" />
                        <Label fx:id="nameErrorLabel" text="" style="-fx-text-fill: #b91c1c; -fx-font-size: 10px;" visible="false" managed="false" />
                    </children>
                </VBox>
                <VBox spacing="8.0">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #334155;" text="Slug" />
                        <TextField fx:id="slugField" promptText="category-slug" />
                    </children>
                </VBox>
                <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #334155;" text="Description" />
                        <HTMLEditor fx:id="descriptionEditor" prefHeight="220.0" />
                    </children>
                </VBox>
                <HBox alignment="CENTER_RIGHT" spacing="12.0">
                    <children>
                        <Button mnemonicParsing="false" onAction="#onSave"
                                styleClass="btn-primary" prefWidth="150" prefHeight="40"
                                text="Save category" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>

