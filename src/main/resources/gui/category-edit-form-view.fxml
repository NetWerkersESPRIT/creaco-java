<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="760.0" prefWidth="1280.0" styleClass="main-container"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gui.CourseCategoryFormController">
    <left>
        <VBox prefWidth="240.0" spacing="25.0" styleClass="sidebar" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="30.0" left="24.0" right="24.0" top="30.0" />
            </padding>
            <children>
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <Label styleClass="sidebar-brand" text="CreaCo" />
                </HBox>
                
                <VBox spacing="12.0">
                    <Button mnemonicParsing="false" onAction="#onCancel" prefWidth="210.0" styleClass="sidebar-item">
                        <graphic>
                            <HBox spacing="15.0" alignment="CENTER_LEFT">
                                <StackPane styleClass="sidebar-icon-box">
                                    <Label text="🏠" style="-fx-font-size: 16px;" />
                                </StackPane>
                                <Label text="Dashboard" />
                            </HBox>
                        </graphic>
                    </Button>
                </VBox>

                <Label styleClass="section-header" text="WORKFLOW MANAGEMENT" />
                <VBox spacing="10.0">
                    <Button mnemonicParsing="false" onAction="#onCancel" prefWidth="210.0" styleClass="sidebar-item, sidebar-item-active">
                        <graphic>
                            <HBox spacing="15.0" alignment="CENTER_LEFT">
                                <StackPane styleClass="sidebar-icon-box">
                                    <Label text="🎓" style="-fx-font-size: 16px;" />
                                </StackPane>
                                <Label text="Courses" />
                            </HBox>
                        </graphic>
                    </Button>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />
                <Button onAction="#logout" text="Log Out" prefHeight="45.0" prefWidth="200.0" styleClass="btn-primary" />
            </children>
        </VBox>
    </left>
    <center>
        <VBox alignment="TOP_CENTER" spacing="24.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="28.0" left="28.0" right="28.0" top="28.0" />
            </padding>
            <children>
                <HBox styleClass="top-nav" alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <VBox>
                            <Label style="-fx-text-fill: #a0aec0; -fx-font-size: 12px;" text="Pages / Categories / Edit" />
                            <Label fx:id="titleLabel" styleClass="title-label" text="Add Category" />
                            <Label fx:id="subtitleLabel" style="-fx-text-fill: -fx-primary-pink; -fx-font-size: 11px;" text="Create a new course category." />
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#logout" styleClass="btn-logout">
                            <graphic>
                                <Label text="🏃" style="-fx-text-fill: white; -fx-font-size: 16px;" />
                            </graphic>
                        </Button>
                    </children>
                </HBox>
                <VBox maxWidth="860.0" spacing="20.0" styleClass="card">
                    <padding>
                        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                    </padding>
                    <children>
                        <VBox spacing="4.0">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-text-fill: #334155;" text="Name *" />
                                <TextField fx:id="nameField" promptText="Category name" />
                                <Label fx:id="nameErrorLabel" text="" style="-fx-text-fill: #b91c1c; -fx-font-size: 12px;" visible="false" managed="false" />
                            </children>
                        </VBox>
                        <VBox spacing="8.0">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-text-fill: #334155;" text="Slug" />
                                <TextField fx:id="slugField" promptText="category-slug" />
                            </children>
                        </VBox>
                        <VBox spacing="8.0">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-text-fill: #334155;" text="Description" />
                                <TextArea fx:id="descriptionArea" prefHeight="220.0" promptText="Describe this category..." wrapText="true" />
                            </children>
                        </VBox>
                        <HBox alignment="CENTER_RIGHT" spacing="12.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#onCancel"
                                        styleClass="btn-secondary" prefWidth="120" prefHeight="40"
                                        text="Cancel" />
                                <Button mnemonicParsing="false" onAction="#onSave"
                                        styleClass="btn-primary" prefWidth="150" prefHeight="40"
                                        text="Save category" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>
