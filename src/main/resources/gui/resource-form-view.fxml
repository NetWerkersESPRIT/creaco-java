<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="760.0" prefWidth="1280.0" styleClass="main-container"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gui.RessourceFormController">
    <left>
        <fx:include source="sidebar.fxml" />
    </left>
    <center>
        <VBox alignment="TOP_CENTER" spacing="24.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="28.0" left="28.0" right="28.0" top="28.0" />
            </padding>
            <children>
                <HBox styleClass="top-nav" alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Button onAction="#onCancel" styleClass="btn-action-light" style="-fx-font-size: 20px; -fx-padding: 5 12; -fx-background-radius: 12;" text="⬅" />
                            <VBox>
                                <Label style="-fx-text-fill: #a0aec0; -fx-font-size: 12px;" text="Pages / Courses / Resources / Edit" />
                                <Label fx:id="titleLabel" styleClass="title-label" text="Add Resource" />
                                <Label fx:id="subtitleLabel" style="-fx-text-fill: -fx-primary-pink; -fx-font-size: 11px;" text="Create a new resource." />
                            </VBox>
                        </HBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#logout" styleClass="btn-logout">
                            <graphic>
                                <Label text="🏃" style="-fx-text-fill: white; -fx-font-size: 16px;" />
                            </graphic>
                        </Button>
                    </children>
                </HBox>
                <VBox maxWidth="860.0" spacing="20.0" styleClass="card">
                    <padding>
                        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                    </padding>
                    <children>
                        <VBox spacing="4.0">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-text-fill: #334155;" text="Name *" />
                                <TextField fx:id="nameField" promptText="Resource name" />
                                <Label fx:id="nameErrorLabel" text="" style="-fx-text-fill: #b91c1c; -fx-font-size: 12px;" visible="false" managed="false" />
                            </children>
                        </VBox>

                        <VBox spacing="4.0">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-text-fill: #334155;" text="Resource *" />
                                <HBox spacing="10">
                                    <TextField fx:id="urlField" promptText="Upload a file or provide a URL" HBox.hgrow="ALWAYS" editable="false" />
                                    <Button text="Browse" onAction="#onBrowseFile" styleClass="btn-secondary" />
                                </HBox>
                                <Label fx:id="urlErrorLabel" text="" style="-fx-text-fill: #b91c1c; -fx-font-size: 12px;" visible="false" managed="false" />
                            </children>
                        </VBox>
                        <VBox spacing="8.0">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-text-fill: #334155;" text="Content" />
                                <TextArea fx:id="contentArea" prefHeight="220.0" promptText="Optional content or notes..." wrapText="true" />
                            </children>
                        </VBox>
                        <HBox alignment="CENTER_RIGHT" spacing="12.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#onSave"
                                        styleClass="btn-primary" prefWidth="150" prefHeight="40"
                                        text="Save resource" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>
