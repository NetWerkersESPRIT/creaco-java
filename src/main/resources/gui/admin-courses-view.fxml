<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.*?>

<VBox spacing="25.0" styleClass="dashboard-container" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.MainController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
    
    <children>
        <!-- Welcome Header -->
        <VBox spacing="5.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <children>
                        <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Course Management" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label style="-fx-text-fill: #64748b; -fx-font-weight: bold;" text="Tuesday, 12 May 2026" />
                    </children>
                </HBox>
                <Label style="-fx-text-fill: #64748b; -fx-font-size: 14px;" text="Manage your curriculum, track engagement, and generate AI-powered drafts." />
            </children>
            <padding>
                <Insets bottom="10.0" />
            </padding>
        </VBox>

        <!-- Stats Row -->
        <HBox spacing="20.0" alignment="CENTER_LEFT">
            <children>
                <VBox spacing="8.0" styleClass="stat-card" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 5);">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <children>
                                <Label text="📚" style="-fx-font-size: 20px;"/>
                                <Label styleClass="stat-title" text="TOTAL COURSES" style="-fx-text-fill: #64748b; -fx-font-weight: bold; -fx-font-size: 11px;"/>
                            </children>
                        </HBox>
                        <Label fx:id="lblTotalCourses" styleClass="stat-value" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    </children>
                </VBox>
                <VBox spacing="8.0" styleClass="stat-card" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 5);">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <children>
                                <Label text="🛠️" style="-fx-font-size: 20px;"/>
                                <Label styleClass="stat-title" text="ACTIVE WORKSHOPS" style="-fx-text-fill: #64748b; -fx-font-weight: bold; -fx-font-size: 11px;"/>
                            </children>
                        </HBox>
                        <Label fx:id="lblActiveWorkshops" styleClass="stat-value" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    </children>
                </VBox>
                <VBox spacing="8.0" styleClass="stat-card" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 5);">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <children>
                                <Label text="🏷️" style="-fx-font-size: 20px;"/>
                                <Label styleClass="stat-title" text="TOTAL CATEGORIES" style="-fx-text-fill: #64748b; -fx-font-weight: bold; -fx-font-size: 11px;"/>
                            </children>
                        </HBox>
                        <Label fx:id="lblTotalCategories" styleClass="stat-value" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    </children>
                </VBox>
            </children>
        </HBox>

        <!-- Actions Row -->
        <FlowPane hgap="15.0" vgap="15.0" alignment="CENTER_LEFT" styleClass="card" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 15; -fx-border-color: #e2e8f0; -fx-border-radius: 15; -fx-border-width: 1;">
            <children>
                <TextField fx:id="searchField" promptText="Search courses by title..." prefWidth="400" styleClass="search-bar" style="-fx-background-color: #f8fafc; -fx-text-fill: #1e293b; -fx-prompt-text-fill: #94a3b8; -fx-border-color: #e2e8f0; -fx-background-radius: 10; -fx-border-radius: 10;" />
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <children>
                        <Button onAction="#onManageCategories" prefHeight="40.0" styleClass="btn-standard-grey" text="⚙ Manage Categories" />
                        <Button onAction="#onShowHelpDesk" prefHeight="40.0" styleClass="btn-standard-grey" text="🎧 Help Desk" />
                        <Separator orientation="VERTICAL" style="-fx-opacity: 0.5;" />
                        <Button onAction="#onShowAIDraft" prefHeight="40.0" styleClass="btn-standard-ai" text="✨ AI Draft" />
                        <Button onAction="#onAddCourse" prefHeight="40.0" styleClass="btn-standard-pink" text="+ Add Course" />
                    </children>
                </HBox>
            </children>
        </FlowPane>

        <!-- Main Content Area -->
        <VBox VBox.vgrow="ALWAYS">
            <children>
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
                    <content>
                        <FlowPane fx:id="coursesContainer" hgap="25.0" vgap="25.0" prefWrapLength="1100">
                            <padding>
                                <Insets bottom="30.0" left="10.0" right="10.0" top="10.0" />
                            </padding>
                        </FlowPane>
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </children>
</VBox>
