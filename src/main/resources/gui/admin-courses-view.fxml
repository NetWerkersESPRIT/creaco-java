<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.*?>

<VBox spacing="25.0" styleClass="dashboard-container" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.MainController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
    
    <children>
        <!-- Header Section -->
        <VBox spacing="5.0">
            <Label styleClass="title-label" text="Course Management" />
            <Label fx:id="statusLabel" styleClass="subtitle-label" text="Manage your workshops and generate new content with AI." />
        </VBox>

        <!-- Stats Row -->
        <HBox spacing="20.0" alignment="CENTER_LEFT">
            <children>
                <VBox spacing="5.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <children>
                        <Label styleClass="stat-title" text="TOTAL COURSES" />
                        <Label fx:id="lblTotalCourses" styleClass="stat-value" text="0" />
                    </children>
                </VBox>
                <VBox spacing="5.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <children>
                        <Label styleClass="stat-title" text="ACTIVE WORKSHOPS" />
                        <Label fx:id="lblActiveWorkshops" styleClass="stat-value" text="0" />
                    </children>
                </VBox>
                <VBox spacing="5.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <children>
                        <Label styleClass="stat-title" text="TOTAL CATEGORIES" />
                        <Label fx:id="lblTotalCategories" styleClass="stat-value" text="0" />
                    </children>
                </VBox>
            </children>
        </HBox>

        <!-- Actions Row -->
        <HBox spacing="15.0" alignment="CENTER_LEFT" styleClass="card">
            <children>
                <TextField fx:id="searchField" promptText="Search courses by title or description..." styleClass="search-bar" HBox.hgrow="ALWAYS" />
                <Button onAction="#onManageCategories" prefHeight="45.0" styleClass="btn-action-light" text="Manage Categories" />
                <Button onAction="#onAddCourse" prefHeight="45.0" styleClass="btn-primary" text="+ Add New Course" />
            </children>
        </HBox>

        <!-- Grid and AI Studio Row -->
        <HBox spacing="25.0" VBox.vgrow="ALWAYS">
            <children>
                <!-- Courses Grid -->
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="scroll-pane" HBox.hgrow="ALWAYS">
                    <content>
                        <FlowPane fx:id="coursesContainer" hgap="20.0" vgap="20.0" prefWrapLength="800">
                            <padding>
                                <Insets bottom="20.0" left="5.0" right="5.0" top="10.0" />
                            </padding>
                        </FlowPane>
                    </content>
                </ScrollPane>

                <!-- AI Course Studio Sidebar -->
                <VBox spacing="20.0" styleClass="card" prefWidth="380.0" minWidth="380.0" style="-fx-background-color: linear-gradient(to bottom right, #ffffff, #f8fafc); -fx-border-color: #e2e8f0; -fx-border-radius: 15; -fx-border-width: 1;">
                    <children>
                        <HBox spacing="12.0" alignment="CENTER_LEFT">
                            <children>
                                <StackPane style="-fx-background-color: -fx-primary-gradient; -fx-background-radius: 10; -fx-padding: 8;">
                                    <Label text="✨" style="-fx-font-size: 18px; -fx-text-fill: white;" />
                                </StackPane>
                                <VBox>
                                    <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="AI Course Studio" />
                                    <Label style="-fx-font-size: 10px; -fx-text-fill: #ec4899; -fx-font-weight: bold;" text="GENERATE CONTENT INSTANTLY" />
                                </VBox>
                            </children>
                        </HBox>
                        
                        <Label styleClass="subtitle-label" text="Type a topic and our AI will draft a complete course structure for you." wrapText="true" />
                        
                        <VBox spacing="8.0">
                            <Label style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 11px;" text="TOPIC OR KEYWORDS" />
                            <TextField fx:id="aiTopicField" promptText="e.g. Advanced JavaFX UI Design" styleClass="search-bar" />
                        </VBox>
                        
                        <Button fx:id="btnGenerateIdea" onAction="#onGenerateCourseIdea" prefHeight="45.0" prefWidth="Infinity" styleClass="btn-primary" style="-fx-background-color: #2d3748;" text="Generate Course Draft" />
                        
                        <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                            <Label style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 11px;" text="GENERATED OUTLINE" />
                            <TextArea fx:id="aiResultArea" promptText="Generated content will appear here..." wrapText="true" VBox.vgrow="ALWAYS" style="-fx-font-size: 12px; -fx-control-inner-background: #ffffff;" />
                        </VBox>
                        
                        <Button fx:id="btnDraftCourse" onAction="#onDraftCourse" prefHeight="45.0" prefWidth="Infinity" styleClass="btn-primary" text="Use this Draft" disable="true" />
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>