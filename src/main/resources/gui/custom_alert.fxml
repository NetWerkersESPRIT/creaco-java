<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane style="-fx-background-color: rgba(0,0,0,0.5);" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <VBox alignment="CENTER" maxWidth="450.0" spacing="25.0" style="-fx-background-color: white; -fx-background-radius: 24; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 20, 0, 0, 10);">
         <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
         </padding>
         <children>
            <StackPane maxHeight="100.0" maxWidth="100.0" minHeight="100.0" minWidth="100.0" style="-fx-border-color: #cbd5e1; -fx-border-radius: 50; -fx-border-width: 2;">
               <children>
                  <Label fx:id="iconLabel" style="-fx-font-size: 40px; -fx-text-fill: #64748b;" text="?" />
               </children>
            </StackPane>
            
            <VBox alignment="CENTER" spacing="10.0">
               <children>
                  <Label fx:id="titleLabel" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Approve Post?" />
                  <Label fx:id="messageLabel" alignment="CENTER" style="-fx-font-size: 15px; -fx-text-fill: #64748b; -fx-text-alignment: center;" text="Are you sure you want to approve this post? It will become visible to all users." wrapText="true" />
               </children>
            </VBox>
            
            <HBox alignment="CENTER" spacing="20.0">
               <children>
                  <Button fx:id="cancelBtn" mnemonicParsing="false" prefHeight="45.0" prefWidth="120.0" style="-fx-background-color: #94a3b8; -fx-text-fill: white; -fx-background-radius: 12; -fx-font-weight: bold; -fx-cursor: hand;" text="Cancel" />
                  <Button fx:id="confirmBtn" mnemonicParsing="false" prefHeight="45.0" prefWidth="150.0" style="-fx-background-color: #ce2d7c; -fx-text-fill: white; -fx-background-radius: 12; -fx-font-weight: bold; -fx-cursor: hand;" text="Yes, Approve" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</StackPane>
