<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane style="-fx-background-color: rgba(0,0,0,0.4);" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <VBox alignment="CENTER" maxWidth="400" maxHeight="250" spacing="20.0" styleClass="card" style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 20, 0, 0, 5);">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
            <children>
                <Label fx:id="iconLabel" style="-fx-font-size: 36px; -fx-text-fill: -fx-primary-pink; -fx-font-weight: bold;" text="?" />
                <VBox alignment="CENTER" spacing="8.0">
                    <children>
                        <Label fx:id="titleLabel" styleClass="title-label" style="-fx-font-size: 20px; -fx-alignment: center;" text="Confirm" wrapText="true" textAlignment="CENTER" />
                        <Label fx:id="messageLabel" styleClass="subtitle-label" style="-fx-font-size: 14px; -fx-text-fill: #475569; -fx-alignment: center;" text="Are you sure?" wrapText="true" textAlignment="CENTER" />
                    </children>
                </VBox>
                <HBox alignment="CENTER" spacing="15.0">
                    <children>
                        <Button fx:id="cancelBtn" mnemonicParsing="false" styleClass="btn-action-light" style="-fx-padding: 8 20; -fx-font-size: 14px; -fx-font-weight: bold;" text="Cancel" />
                        <Button fx:id="confirmBtn" mnemonicParsing="false" styleClass="btn-primary" style="-fx-padding: 8 20; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-color: #ce2d7c; -fx-text-fill: white;" text="Confirm" />
                    </children>
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>
