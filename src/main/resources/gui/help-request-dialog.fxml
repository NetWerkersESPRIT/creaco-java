<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15.0" styleClass="card" stylesheets="@styles.css" 
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="gui.HelpRequestController">
    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
    </padding>
    <children>
        <VBox spacing="5.0">
            <Label styleClass="title-label" style="-fx-font-size: 18px;" text="Request Mentor Assistance" />
            <Label style="-fx-text-fill: #64748b;" text="Explain your technical or pedagogical difficulty." />
        </VBox>
        
        <VBox spacing="8.0">
            <Label style="-fx-font-weight: bold;" text="Subject *" />
            <TextField fx:id="subjectField" promptText="e.g., Upload issue, JavaFX question..." />
        </VBox>

        <VBox spacing="8.0">
            <Label style="-fx-font-weight: bold;" text="Priority *" />
            <ComboBox fx:id="priorityCombo" prefWidth="400.0" promptText="Select priority" />
        </VBox>

        <VBox spacing="8.0">
            <Label style="-fx-font-weight: bold;" text="Message / Details *" />
            <TextArea fx:id="messageArea" prefHeight="150.0" promptText="Describe your problem here..." wrapText="true" />
        </VBox>

        <HBox alignment="CENTER_RIGHT" spacing="12.0">
            <Button onAction="#onCancel" styleClass="btn-secondary" text="Cancel" />
            <Button onAction="#onSubmit" styleClass="btn-primary" text="Send Request" />
        </HBox>
    </children>
</VBox>
