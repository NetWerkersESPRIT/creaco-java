<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox spacing="25.0" styleClass="dashboard-container" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.CourseCategoryListController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <!-- Header Section (Only Back Button) -->
    <HBox alignment="CENTER_LEFT" spacing="15.0">
        <Button onAction="#onBackToCourses" styleClass="btn-action-light" style="-fx-background-radius: 50%; -fx-min-width: 45px; -fx-min-height: 45px; -fx-max-width: 45px; -fx-max-height: 45px; -fx-padding: 0;">
            <graphic>
                <FontIcon iconLiteral="fas-arrow-left" iconSize="18" iconColor="#475569"/>
            </graphic>
        </Button>
    </HBox>

    <!-- Column Headers -->
    <HBox alignment="CENTER_LEFT" spacing="18.0" style="-fx-padding: 0 15 0 15;">
        <Label text="NAME" style="-fx-text-fill: #94a3b8; -fx-font-weight: bold; -fx-font-size: 11px;" minWidth="260" />
        <Label text="DESCRIPTION" style="-fx-text-fill: #94a3b8; -fx-font-weight: bold; -fx-font-size: 11px;" minWidth="360" />
        <Label text="DATES" style="-fx-text-fill: #94a3b8; -fx-font-weight: bold; -fx-font-size: 11px;" minWidth="150" />
        <Region HBox.hgrow="ALWAYS" />
        <Label text="ACTIONS" style="-fx-text-fill: #94a3b8; -fx-font-weight: bold; -fx-font-size: 11px;" />
    </HBox>

    <!-- Categories List Container -->
    <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: transparent;">
        <content>
            <VBox fx:id="categoriesContainer" spacing="15.0">
                <padding>
                    <Insets bottom="10.0" left="5.0" right="15.0" top="5.0" />
                </padding>
            </VBox>
        </content>
    </ScrollPane>

</VBox>

