<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.*?>

<StackPane fx:id="rootStack" prefHeight="760.0" prefWidth="1280.0" styleClass="main-container"
           xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="gui.FrontResourceController" stylesheets="@styles.css">

    <BorderPane>

    <left>
        <fx:include source="sidebar.fxml" />
    </left>

    <center>
        <VBox fx:id="mainContent" spacing="22.0">
            <padding>
                <Insets top="24" left="24" right="24" bottom="24"/>
            </padding>
            <children>
                <HBox fx:id="previewBanner" alignment="CENTER_LEFT" spacing="15" visible="false" managed="false"
                      style="-fx-background-color: #f1f5f9; -fx-padding: 12 24; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;">
                    <Label text="You are now in preview mode" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 14;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="Exit Preview" onAction="#exitPreview"
                            style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6;" />
                </HBox>

                <HBox styleClass="top-nav" alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <VBox>
                            <Label style="-fx-text-fill: #a0aec0; -fx-font-size: 12px;" text="Pages / Courses / Resources" />
                            <Label fx:id="courseTitleLabel" styleClass="title-label" text="Resources" style="-fx-font-size: 20px;"/>
                        </VBox>
                        
                        <Region HBox.hgrow="ALWAYS" />
                        
                        <HBox fx:id="profileBox" alignment="CENTER" spacing="12" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 5 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 4);">
                            <children>
                                <VBox alignment="CENTER_RIGHT">
                                    <Label text="Welcome" style="-fx-text-fill: -fx-primary-pink; -fx-font-size: 10px; -fx-font-weight: bold;" />
                                    <Label fx:id="lblNavUsername" text="User" style="-fx-text-fill: -fx-text-main; -fx-font-weight: bold; -fx-font-size: 14px;" />
                                </VBox>
                                <Label fx:id="lblNavUserRole" text="USER" styleClass="badge-pink" style="-fx-font-size: 9px; -fx-padding: 2 8;"/>
                            </children>
                        </HBox>


                        <Button fx:id="logoutBtn" onAction="#logout" styleClass="btn-logout" prefHeight="40" prefWidth="40">
                            <graphic>
                                <Label text="🏃" style="-fx-text-fill: white; -fx-font-size: 16px;" />
                            </graphic>
                        </Button>
                    </children>
                </HBox>

                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: transparent; -fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                    <content>
                        <TilePane fx:id="resourcesContainer" hgap="24" vgap="24" prefColumns="3" prefTileWidth="300" tileAlignment="TOP_LEFT" style="-fx-padding: 10;" />
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </center>

    </BorderPane>

    <!-- Floating Button (Bottom Right) -->
    <Button fx:id="askTutorBtn" text="Ask Smart Tutor ✨" onAction="#openTutorModal"
            style="-fx-background-color: linear-gradient(to right, #ec4899, #8b5cf6); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 25; -fx-padding: 12 24; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 15, 0, 0, 5); -fx-cursor: hand;"
            StackPane.alignment="BOTTOM_RIGHT" >
        <StackPane.margin>
            <Insets bottom="30" right="30" />
        </StackPane.margin>
    </Button>

    <!-- Chat Modal Overlay (hidden by default) -->
    <StackPane fx:id="tutorModal" visible="false" style="-fx-background-color: rgba(0,0,0,0.5);">
        <VBox maxHeight="550" maxWidth="450" spacing="15" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 20, 0, 0, 5);">
            <HBox alignment="CENTER_LEFT">
                <Label text="Smart Course Tutor 🤖" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="✕" onAction="#closeTutorModal" style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 18px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0;" />
            </HBox>
            
            <ScrollPane fx:id="chatScroll" fitToWidth="true" vbarPolicy="AS_NEEDED" hbarPolicy="NEVER" VBox.vgrow="ALWAYS" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: #f1f5f9; -fx-border-width: 2; -fx-border-radius: 10;">
                <VBox fx:id="chatBox" spacing="15" style="-fx-padding: 15; -fx-background-color: white;">
                    <!-- Chat bubbles go here -->
                </VBox>
            </ScrollPane>
            
            <HBox spacing="10">
                <TextField fx:id="chatInput" promptText="Ask a question about this course..." HBox.hgrow="ALWAYS" style="-fx-padding: 12; -fx-background-radius: 25; -fx-border-color: #e2e8f0; -fx-border-radius: 25; -fx-font-size: 13px;" onAction="#sendChatMessage" />
                <Button text="Send" onAction="#sendChatMessage" style="-fx-background-color: #ec4899; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 25; -fx-padding: 10 20; -fx-cursor: hand;" />
            </HBox>
        </VBox>
    </StackPane>

    <!-- Resource Detail Modal -->
    <StackPane fx:id="resourceModal" visible="false" style="-fx-background-color: rgba(0,0,0,0.65);">
        <VBox maxWidth="800" maxHeight="600" spacing="25" style="-fx-background-color: white; -fx-background-radius: 24; -fx-padding: 40; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 30, 0, 0, 15);">
            <HBox alignment="CENTER_LEFT">
                <Label fx:id="modalResourceTitle" text="Resource Details" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="✕" onAction="#closeResourceModal" style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 24px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0;" />
            </HBox>
            
            <Separator style="-fx-opacity: 0.5;" />
            
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
                <Label fx:id="modalResourceDesc" text="Description goes here..." wrapText="true" 
                       style="-fx-font-size: 17px; -fx-text-fill: #334155; -fx-line-spacing: 6; -fx-padding: 0 10 0 0;" />
            </ScrollPane>
            
            <HBox alignment="CENTER_RIGHT" spacing="15">
                <Button text="Close Window" onAction="#closeResourceModal" 
                        style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 12 30; -fx-cursor: hand;" />
            </HBox>
        </VBox>
    </StackPane>

</StackPane>
