<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="760.0" prefWidth="1280.0" styleClass="main-container" 
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="gui.FrontResourceController" stylesheets="@styles.css">
    
    <!-- Side bar is managed by FrontMainController shell -->

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: transparent; -fx-background-color: transparent;">
            <content>
                <VBox spacing="30">
                    <padding>
                        <Insets top="24" left="24" right="24" bottom="24"/>
                    </padding>
                    <children>
                        <!-- Header with Back Button -->
                        <HBox alignment="CENTER_LEFT" spacing="20.0">
                            <children>
                                <Button onAction="#goBack" styleClass="btn-action-light" text="← Back to Courses" 
                                        style="-fx-background-radius: 20; -fx-padding: 8 20; -fx-font-weight: bold;" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button fx:id="askTutorBtn" text="✨ Ask AI Tutor" onAction="#openTutorModal" 
                                        styleClass="btn-primary" style="-fx-background-color: #6c2db1; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 8 20;" />
                                <VBox alignment="CENTER_RIGHT">
                                    <Label fx:id="courseTitleLabel" text="Resources" styleClass="title-label" style="-fx-font-size: 24px;" />
                                    <Label text="Course Content &amp; Downloads" style="-fx-text-fill: #a0aec0; -fx-font-size: 12px;" />
                                </VBox>
                            </children>
                        </HBox>


                        <!-- Resources Grid -->
                        <VBox fx:id="mainContent" spacing="20">
                            <TilePane fx:id="resourcesContainer" hgap="24" vgap="24" prefColumns="3" alignment="TOP_LEFT">
                                <!-- Resource cards will be injected here -->
                            </TilePane>
                        </VBox>

                        <!-- Empty State Spacer -->
                        <Region VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <StackPane>
            <!-- Resource Detail Modal -->
            <StackPane fx:id="resourceModal" visible="false" style="-fx-background-color: rgba(0,0,0,0.5);">
                <VBox spacing="20" styleClass="card" maxWidth="600" maxHeight="500" style="-fx-padding: 30; -fx-background-color: white; -fx-background-radius: 20;">
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <Label fx:id="modalResourceTitle" styleClass="title-label" style="-fx-font-size: 22px;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button text="✕" onAction="#closeResourceModal" styleClass="btn-action-light" />
                        </HBox>
                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                            <Label fx:id="modalResourceDesc" wrapText="true" style="-fx-text-fill: #475569; -fx-font-size: 14px;" />
                        </ScrollPane>
                    </children>
                </VBox>
            </StackPane>

            <!-- Quiz Modal -->
            <StackPane fx:id="quizModal" visible="false" style="-fx-background-color: rgba(0,0,0,0.5);">
                <VBox spacing="20" styleClass="card" maxWidth="700" maxHeight="650" style="-fx-padding: 30; -fx-background-color: white; -fx-background-radius: 20;">
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <Label fx:id="quizModalTitle" styleClass="title-label" style="-fx-font-size: 20px;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button text="✕" onAction="#closeQuizModal" styleClass="btn-action-light" />
                        </HBox>
                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                            <VBox fx:id="quizQuestionsContainer" spacing="15" />
                        </ScrollPane>
                        <HBox fx:id="quizResultCard" visible="false" managed="false" alignment="CENTER_LEFT" spacing="15">
                            <Label fx:id="quizResultIcon" />
                            <Label fx:id="quizResultLabel" wrapText="true" />
                        </HBox>
                        <Button fx:id="submitQuizButton" text="Submit Assessment" onAction="#submitQuizAnswers" styleClass="btn-primary" maxWidth="Infinity" />
                    </children>
                </VBox>
            </StackPane>

            <!-- AI Tutor Modal -->
            <StackPane fx:id="tutorModal" visible="false" style="-fx-background-color: rgba(0,0,0,0.5);">
                <VBox spacing="15" styleClass="card" maxWidth="400" maxHeight="600" StackPane.alignment="BOTTOM_RIGHT" style="-fx-padding: 20; -fx-background-color: white; -fx-background-radius: 20; -fx-translate-x: -30; -fx-translate-y: -30;">
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="✨ Smart Tutor" style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #6c2db1;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button text="✕" onAction="#closeTutorModal" styleClass="btn-action-light" />
                        </HBox>
                        <ScrollPane fx:id="chatScroll" fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: #f8fafc; -fx-background-radius: 10;">
                            <VBox fx:id="chatBox" spacing="10" style="-fx-padding: 10;" />
                        </ScrollPane>
                        <HBox spacing="10">
                            <TextField fx:id="chatInput" promptText="Ask a question..." HBox.hgrow="ALWAYS" style="-fx-background-radius: 15;" onAction="#sendChatMessage" />
                            <Button text="Send" onAction="#sendChatMessage" styleClass="btn-primary" style="-fx-background-color: #6c2db1;" />
                        </HBox>
                    </children>
                </VBox>
            </StackPane>
        </StackPane>
    </bottom>
</BorderPane>
