<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.image.ImageView?>

<VBox fx:id="chatRoot" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" 
      prefWidth="320.0" prefHeight="450.0" 
      style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 20, 0, 0, 10); -fx-border-color: #e2e8f0; -fx-border-radius: 15;" 
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="gui.chat.FloatingChatController">
   <children>
      <!-- Header -->
      <HBox alignment="CENTER_LEFT" onMouseDragged="#onHeaderDragged" onMousePressed="#onHeaderPressed" 
            spacing="10.0" style="-fx-padding: 10 15; -fx-background-color: rgba(255,255,255,0.9); -fx-background-radius: 15 15 0 0; -fx-border-color: transparent transparent #f1f5f9 transparent; -fx-cursor: move;">
         <children>
            <StackPane>
               <children>
                  <ImageView fx:id="headerAvatar" fitHeight="36.0" fitWidth="36.0" pickOnBounds="true" preserveRatio="true" />
               </children>
            </StackPane>
            <VBox alignment="CENTER_LEFT">
               <children>
                  <Label fx:id="userNameLabel" text="Admin" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 14px;" />
               </children>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <HBox spacing="5.0">
               <children>
                  <Button onAction="#handleClose" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-text-fill: #94a3b8; -fx-font-size: 10px;" text="❌" />
               </children>
            </HBox>
         </children>
      </HBox>

      <!-- Messages Area -->
      <ScrollPane fx:id="scrollPane" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
         <content>
            <VBox fx:id="messagesContainer" spacing="10.0" style="-fx-padding: 15;">
               <!-- Messages will be injected here -->
            </VBox>
         </content>
      </ScrollPane>



      <!-- Input Area -->
      <HBox alignment="CENTER" spacing="10.0" style="-fx-padding: 10 15; -fx-border-color: #f1f5f9 transparent transparent transparent;">
         <children>
            <Button onAction="#handleAttachFile" minWidth="35" prefWidth="35" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-text-fill: #ce2d7c; -fx-font-size: 18px; -fx-padding: 0;" text="📎" />
            <TextField fx:id="messageInput" onAction="#handleSend" promptText="Type a message..." 
                       HBox.hgrow="ALWAYS" 
                       style="-fx-background-color: #f1f5f9; -fx-background-radius: 20; -fx-padding: 8 15; -fx-border-color: transparent;" />
            <Button onAction="#handleSend" minWidth="65" style="-fx-background-color: -fx-primary-gradient; -fx-background-radius: 18; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15; -fx-cursor: hand;" text="Send" />
         </children>
      </HBox>
   </children>
</VBox>
