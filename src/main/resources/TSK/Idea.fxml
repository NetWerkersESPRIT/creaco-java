<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="760.0" prefWidth="1280.0" styleClass="main-container"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gui.TSKControllers.IdeaController" stylesheets="@../gui/styles.css">
    <center>
        <!-- Outer ScrollPane so the whole page scrolls when content is tall -->
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <content>
                <VBox spacing="0" maxWidth="Infinity">
                    <padding>
                        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                    </padding>
                    <children>

                        <!-- Block 1: Gradient Header + Subtitle -->
                        <VBox spacing="4" style="-fx-padding: 0 0 18 0;">
                            <Label text="Explore Ideas" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #cb0c9f;" />
                            <Label text="Discover and fuel your next big project" style="-fx-font-size: 13px; -fx-text-fill: #94a3b8;" />
                        </VBox>

                        <!-- Block 2: View Switcher + New Idea Button -->
                        <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 0 0 18 0;">
                            <HBox spacing="4" style="-fx-background-color: #f1f5f9; -fx-background-radius: 12; -fx-padding: 4; -fx-border-color: #e2e8f0; -fx-border-radius: 12;">
                                <Button fx:id="btnViewDiscover" text="✦ Discover" onAction="#switchToDiscover"
                                        style="-fx-background-color: white; -fx-text-fill: #cb0c9f; -fx-font-weight: bold; -fx-font-size: 11px; -fx-background-radius: 9; -fx-padding: 7 18; -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.07),6,0,0,2); -fx-cursor: hand;" />
                                <Button fx:id="btnViewBrowse" text="☰ Browse All" onAction="#switchToBrowse"
                                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-weight: bold; -fx-font-size: 11px; -fx-background-radius: 9; -fx-padding: 7 18; -fx-cursor: hand;" />
                            </HBox>
                            <Region HBox.hgrow="ALWAYS" />
                            <Button mnemonicParsing="false" onAction="#handleAddIdea" prefHeight="35.0" styleClass="btn-primary"
                                    text="＋ Add Idea" style="-fx-font-size: 12px;" />
                        </HBox>

                        <!-- Block 3: Search + Category Filter (visible in Browse mode) -->
                        <HBox fx:id="searchBar" alignment="CENTER_LEFT" spacing="12"
                              style="-fx-padding: 0 0 14 0;" managed="false" visible="false">
                            <TextField fx:id="txtSearch" promptText="🔍  Search ideas..." prefHeight="36"
                                       style="-fx-background-color: #f8fafc; -fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-padding: 8 14; -fx-font-size: 13px;"
                                       onKeyReleased="#onSearch" HBox.hgrow="ALWAYS" />
                            <ComboBox fx:id="cmbCategory" promptText="All Categories" prefHeight="36" prefWidth="180"
                                      onAction="#onSearch"
                                      style="-fx-background-color: #f8fafc; -fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-font-size: 13px;" />
                        </HBox>

                        <!-- Separator -->
                        <Separator style="-fx-padding: 0 0 10 0;" />

                        <!-- Block 4: Column Headers -->
                        <HBox fx:id="columnHeaders" spacing="15.0"
                              style="-fx-padding: 10 15 10 15; -fx-background-color: #f8fafc; -fx-background-radius: 10;"
                              managed="false" visible="false">
                            <Label text="IDEA DETAILS" style="-fx-font-weight: bold; -fx-text-fill: #64748b; -fx-font-size: 11px;" prefWidth="300"/>
                            <Region HBox.hgrow="ALWAYS" />
                            <Label text="CATEGORY" style="-fx-font-weight: bold; -fx-text-fill: #64748b; -fx-font-size: 11px;" prefWidth="190" />
                            <Label text="ACTIONS" style="-fx-font-weight: bold; -fx-text-fill: #64748b; -fx-font-size: 11px;" prefWidth="70" />
                        </HBox>

                        <!-- Block 5: Ideas List — expands to fit all items, no fixed height -->
                        <VBox fx:id="ideasList" spacing="8.0"
                              style="-fx-background-color: transparent; -fx-padding: 8 0 0 0;"
                              maxHeight="Infinity" />

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
